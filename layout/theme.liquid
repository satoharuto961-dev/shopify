<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GRKJWGBWMK"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-GRKJWGBWMK');
    </script>
    <!-- Google Tag Manager -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-M2H2S2ZK');</script>
    <!-- End Google Tag Manager -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title | escape }}</title>
    <link rel="icon" href="{{ 'favicon.svg' | asset_url }}" type="image/svg+xml">
    {{ content_for_header }}
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    <style>
      /* CRITICAL: Force home page background color */
      body.template-index {
        background-color: #E3F0E8 !important;
        background: #E3F0E8 !important;
      }
      
      /* Reset for Bundle Landing Pages - Removes white space gaps */
      body[class*="template-suffix-"] .site-main {
        margin: 0 !important;
        padding: 0 !important;
      }
      body[class*="template-suffix-"] .page {
        margin: 0 !important;
        padding: 0 !important;
      }
      /* Ensure sections within bundles don't have stray bottom margins revealing white body */
      body[class*="template-suffix-"] .site-footer {
        margin-top: 0 !important;
      }
    </style>
    {% render 'facebook-pixel-fix' %}
  </head>
  <body class="template-{{ template | replace: '.', '-' }}{% if template.name %} template-name-{{ template.name | handleize }}{% endif %}{% if template.suffix %} template-suffix-{{ template.suffix | handleize }}{% endif %}">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M2H2S2ZK"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <!-- ── Announcement Bar ── -->
    <div class="announce-bar" role="complementary" aria-label="Promotional offers">
      <div class="announce-track">
        <!-- Duplicated for seamless loop -->
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
        <!-- Second copy for seamless marquee -->
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
        <span class="announce-item"><span class="tag">🎁 Limited-time offer!</span> Buy one get 5 free</span>
        <span class="announce-dot">✦</span>
      </div>
    </div>
    <style>
      .announce-bar {
        background: #0f172a;
        color: #fff;
        padding: 10px 0;
        overflow: hidden;
        width: 100%;
        position: sticky;
        top: 0;
        z-index: 1000;
      }
      .announce-track {
        display: flex;
        align-items: center;
        gap: 60px;
        width: max-content;
        animation: announce-marquee 30s linear infinite;
        white-space: nowrap;
      }
      .announce-bar:hover .announce-track { animation-play-state: paused; }
      @keyframes announce-marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      .announce-item {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        color: #e2e8f0;
      }
      .announce-item strong { color: #fcd34d; }
      .announce-item .tag {
        background: #f59e0b;
        color: #0f172a;
        border-radius: 4px;
        padding: 2px 8px;
        font-size: 0.68rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }
      .announce-dot { color: #f59e0b; font-size: 1rem; }
    </style>

    <header class="site-header" role="banner">
      <div class="header-inner">
        <a class="brand" href="/">
          <span class="brand-mark" aria-hidden="true">gr</span>
          <span class="brand-text">
            <span class="brand-name">{{ shop.name | default: 'PsychoReads' | escape }}</span>
            <span class="brand-tagline">Readers' community</span>
          </span>
        </a>
        <div class="header-navigation">
          <nav class="primary-nav" aria-label="Primary navigation">
            <ul>
              <li><a href="/#lists">Lists</a></li>
              <li><a href="/#new-releases">New Releases</a></li>
              <li><a href="/#community">Community</a></li>
              <li><a href="/#quotes">Quotes</a></li>
            </ul>
          </nav>
        <div class="header-auth">
            {% if customer %}
              <a class="header-auth__link header-auth__link--account" href="/account">
                Hi, {{ customer.first_name | default: customer.email | escape }}
              </a>
              <a class="header-auth__link header-auth__link--logout" href="/account/logout">Sign out</a>
            {% else %}
              <a class="header-auth__link" href="/account/login">Sign in</a>
              <a class="header-auth__cta" href="/account/register">Join</a>
            {% endif %}
        </div>
      </div>
    </header>
    <main class="site-main{% if template.name == 'index' or template == 'index' %} site-main--full-bleed{% endif %}" role="main">
      {{ content_for_layout }}
    </main>
    <footer class="site-footer" role="contentinfo">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="brand-mark brand-mark--footer" aria-hidden="true">gr</span>
          <p>Track the books you&apos;re reading, discover recommendations, and join conversations with readers everywhere.</p>
        </div>
        <div class="footer-links">
          <h3>Discover</h3>
          <ul>
            <li><a href="/#lists">Trending lists</a></li>
            <li><a href="/#new-releases">New Releases</a></li>
            <li><a href="/collections/all">Browse all books</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h3>Community</h3>
          <ul>
            <li><a href="/account/register">Create an account</a></li>
            <li><a href="/#community">Join discussions</a></li>
            <li><a href="/pages/contact">Contact support</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h3>Connect</h3>
          <ul>
            <li><a href="mailto:{{ shop.email | default: 'support@example.com' | escape }}">Email us</a></li>
            <li><a href="https://www.instagram.com" rel="noopener noreferrer" target="_blank">Instagram</a></li>
            <li><a href="https://www.facebook.com" rel="noopener noreferrer" target="_blank">Facebook</a></li>
          </ul>
        </div>
        <div class="footer-bottom">
          <span>© {{ 'now' | date: '%Y' }} {{ shop.name | default: 'PsychoReads' | escape }}. All rights reserved.</span>
          <div class="footer-bottom__links">
            <a href="/policies/privacy-policy">Privacy</a>
            <a href="/policies/terms-of-service">Terms</a>
        </div>
      </div>
    </footer>
    {{ 'theme.js' | asset_url | script_tag }}
    {{ content_for_footer }}
  </body>
</html>
