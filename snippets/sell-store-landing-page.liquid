{% assign sl_product = all_products['ready-to-launch-shopify-digital-products-store-60-products-proven-500k-system'] %}
{% assign sl_variant = sl_product.variants.first %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Launch Your Own Digital Product Store Today — $70</title>
  <meta name="description" content="Get a fully built Shopify store with 60 digital products, premium custom theme, and a proven system that generated over $500,000 in sales — only $70." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --brand: #4F46E5;
      --brand-dark: #3730a3;
      --brand-light: #EEF2FF;
      --accent: #7C3AED;
      --text-primary: #0f1623;
      --text-secondary: #4B5563;
      --text-muted: #9CA3AF;
      --bg: #ffffff;
      --surface: #F9FAFB;
      --border: #E5E7EB;
      --success: #059669;
      --radius: 14px;
      --shadow: 0 4px 24px rgba(79,70,229,0.10);
      --shadow-lg: 0 12px 48px rgba(79,70,229,0.16);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text-primary);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    /* ── NAV ── */
    .sl-nav {
      position: sticky;
      top: 0;
      z-index: 999;
      background: rgba(255,255,255,0.92);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      padding: 0 24px;
    }
    .sl-nav-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 62px;
    }
    .sl-nav-logo {
      font-weight: 800;
      font-size: 1.1rem;
      color: var(--brand);
      letter-spacing: -0.5px;
    }
    .sl-nav-cta {
      background: var(--brand);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 9px 22px;
      font-size: 0.88rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .sl-nav-cta:hover { background: var(--brand-dark); transform: translateY(-1px); color: #fff; }

    /* ── HERO ── */
    .sl-hero {
      position: relative;
      overflow: hidden;
      background: linear-gradient(135deg, #ffffff 0%, #EEF2FF 50%, #F5F3FF 100%);
      padding: 100px 24px 90px;
      text-align: center;
    }
    .sl-hero::before {
      content: '';
      position: absolute;
      top: -180px; left: 50%;
      transform: translateX(-50%);
      width: 900px; height: 600px;
      background: radial-gradient(ellipse at center, rgba(79,70,229,0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .sl-hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--brand-light);
      color: var(--brand);
      border: 1px solid #C7D2FE;
      border-radius: 999px;
      padding: 5px 16px;
      font-size: 0.8rem;
      font-weight: 600;
      margin-bottom: 28px;
      letter-spacing: 0.3px;
    }
    .sl-hero h1 {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      color: var(--text-primary);
      line-height: 1.15;
      letter-spacing: -1.5px;
      max-width: 800px;
      margin: 0 auto 22px;
    }
    .sl-hero h1 em {
      font-style: normal;
      background: linear-gradient(135deg, var(--brand), var(--accent));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .sl-hero-sub {
      font-size: clamp(1rem, 2.5vw, 1.2rem);
      color: var(--text-secondary);
      max-width: 640px;
      margin: 0 auto 40px;
      line-height: 1.7;
    }
    .sl-hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 14px;
      justify-content: center;
      margin-bottom: 48px;
    }
    .sl-btn-primary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: linear-gradient(135deg, var(--brand), var(--accent));
      color: #fff;
      border: none;
      border-radius: 12px;
      padding: 17px 36px;
      font-size: 1.05rem;
      font-weight: 800;
      cursor: pointer;
      text-decoration: none;
      box-shadow: 0 8px 32px rgba(79,70,229,0.35);
      transition: transform 0.2s, box-shadow 0.2s;
      letter-spacing: -0.3px;
    }
    .sl-btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(79,70,229,0.45);
      color: #fff;
    }
    .sl-btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #fff;
      color: var(--brand);
      border: 2px solid var(--brand);
      border-radius: 12px;
      padding: 15px 28px;
      font-size: 1rem;
      font-weight: 700;
      cursor: pointer;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s;
    }
    .sl-btn-secondary:hover {
      background: var(--brand-light);
      transform: translateY(-2px);
      color: var(--brand);
    }

    /* Trust Badges */
    .sl-trust-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      justify-content: center;
    }
    .sl-badge {
      display: flex;
      align-items: center;
      gap: 7px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px 18px;
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-primary);
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
    }
    .sl-hero-img {
      margin-top: 56px;
    }
    .sl-hero-img img {
      max-width: 860px;
      width: 100%;
      border-radius: 20px;
      box-shadow: 0 24px 80px rgba(79,70,229,0.22);
      border: 1px solid rgba(79,70,229,0.12);
    }

    /* ── SECTIONS ── */
    .sl-section { padding: 90px 24px; }
    .sl-section-inner { max-width: 1100px; margin: 0 auto; }
    .sl-label {
      font-size: 0.78rem;
      font-weight: 700;
      letter-spacing: 2px;
      text-transform: uppercase;
      color: var(--brand);
      margin-bottom: 12px;
    }
    .sl-title {
      font-size: clamp(1.7rem, 3.5vw, 2.6rem);
      font-weight: 900;
      color: var(--text-primary);
      letter-spacing: -1px;
      line-height: 1.18;
      margin-bottom: 16px;
    }
    .sl-sub {
      font-size: 1.05rem;
      color: var(--text-secondary);
      max-width: 600px;
      line-height: 1.7;
    }

    /* ── PROOF ── */
    .sl-proof { background: var(--surface); }
    .sl-proof-header { text-align: center; margin-bottom: 60px; }
    .sl-proof-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
      gap: 32px;
      margin-bottom: 40px;
    }
    .sl-proof-card {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      box-shadow: var(--shadow);
      transition: transform 0.25s, box-shadow 0.25s;
    }
    .sl-proof-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-lg); }
    .sl-proof-card img { width: 100%; display: block; border-bottom: 1px solid var(--border); }
    .sl-proof-caption {
      padding: 16px 20px;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .sl-proof-caption::before {
      content: '✓';
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 22px; height: 22px;
      background: #D1FAE5;
      color: var(--success);
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 800;
      flex-shrink: 0;
    }
    .sl-proof-note {
      text-align: center;
      background: var(--brand-light);
      border: 1px solid #C7D2FE;
      border-radius: 12px;
      padding: 20px 28px;
      font-size: 1rem;
      font-weight: 600;
      color: var(--brand-dark);
      max-width: 720px;
      margin: 0 auto;
    }

    /* ── FEATURES ── */
    .sl-features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 50px;
    }
    .sl-feature-item {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 22px 24px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .sl-feature-item:hover { border-color: var(--brand); box-shadow: 0 0 0 4px rgba(79,70,229,0.07); }
    .sl-check {
      width: 30px; height: 30px;
      background: linear-gradient(135deg, var(--brand), var(--accent));
      border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      color: #fff; font-size: 0.82rem; font-weight: 900;
      flex-shrink: 0; margin-top: 2px;
    }
    .sl-feature-text { font-size: 0.97rem; font-weight: 600; color: var(--text-primary); }
    .sl-feature-sub { font-size: 0.83rem; color: var(--text-muted); margin-top: 2px; }

    /* ── WHY ── */
    .sl-why { background: linear-gradient(135deg, #0f1623 0%, #1e1b4b 100%); color: #fff; }
    .sl-why .sl-title { color: #fff; }
    .sl-why .sl-sub { color: #C7D2FE; }
    .sl-why-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 20px;
      margin-top: 50px;
    }
    .sl-why-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      border-radius: var(--radius);
      padding: 28px 24px;
      transition: background 0.2s;
    }
    .sl-why-card:hover { background: rgba(255,255,255,0.10); }
    .sl-why-icon { font-size: 1.8rem; margin-bottom: 14px; }
    .sl-why-title { font-size: 1.02rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
    .sl-why-text { font-size: 0.88rem; color: #A5B4FC; line-height: 1.6; }

    /* ── STEPS ── */
    .sl-steps { background: var(--surface); }
    .sl-steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      margin-top: 60px;
      position: relative;
    }
    .sl-steps-grid::before {
      content: '';
      position: absolute;
      top: 44px; left: 10%; right: 10%;
      height: 2px;
      background: linear-gradient(90deg, var(--brand), var(--accent));
      opacity: 0.2;
    }
    .sl-step { text-align: center; padding: 20px 24px 40px; }
    .sl-step-num {
      width: 56px; height: 56px;
      background: linear-gradient(135deg, var(--brand), var(--accent));
      border-radius: 999px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; font-weight: 900; color: #fff;
      margin: 0 auto 20px;
      box-shadow: 0 6px 20px rgba(79,70,229,0.35);
    }
    .sl-step-title { font-size: 1.05rem; font-weight: 800; margin-bottom: 8px; }
    .sl-step-text { font-size: 0.88rem; color: var(--text-secondary); }

    /* ── RECEIVE ── */
    .sl-receive-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 40px;
      align-items: start;
      margin-top: 50px;
    }
    .sl-receive-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }
    .sl-receive-list li {
      display: flex; align-items: center; gap: 12px;
      font-size: 0.97rem; font-weight: 500;
    }
    .sl-receive-list li::before { content: '→'; color: var(--brand); font-weight: 900; }
    .sl-bonus-card {
      background: linear-gradient(135deg, #EEF2FF, #F5F3FF);
      border: 2px solid var(--brand);
      border-radius: var(--radius);
      padding: 32px 28px;
      text-align: center;
    }
    .sl-bonus-label {
      font-size: 0.72rem; font-weight: 800; letter-spacing: 2.5px;
      text-transform: uppercase; color: var(--brand); margin-bottom: 12px;
    }
    .sl-bonus-title { font-size: 1.35rem; font-weight: 900; margin-bottom: 10px; }
    .sl-bonus-sub { font-size: 0.9rem; color: var(--text-secondary); }
    .sl-bonus-icon { font-size: 3rem; margin-bottom: 14px; display: block; }

    /* ── PRICING ── */
    .sl-pricing { background: var(--surface); }
    .sl-price-table {
      max-width: 700px;
      margin: 50px auto 0;
      background: #fff;
      border: 1px solid var(--border);
      border-radius: 20px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
    }
    .sl-price-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 18px 28px;
      border-bottom: 1px solid var(--border);
      font-size: 0.97rem;
    }
    .sl-price-label { font-weight: 500; color: var(--text-secondary); }
    .sl-price-value { font-weight: 700; color: var(--text-muted); text-decoration: line-through; }
    .sl-price-divider { height: 4px; background: linear-gradient(90deg, var(--brand), var(--accent)); }
    .sl-price-total {
      padding: 28px;
      display: flex; flex-direction: column; align-items: center; gap: 6px;
    }
    .sl-total-label {
      font-size: 0.82rem; font-weight: 700; letter-spacing: 1.5px;
      text-transform: uppercase; color: var(--text-muted);
    }
    .sl-total-crossed { font-size: 1.3rem; font-weight: 700; color: var(--text-muted); text-decoration: line-through; }
    .sl-total-price { font-size: 3.5rem; font-weight: 900; color: var(--brand); letter-spacing: -2px; line-height: 1; }
    .sl-total-per { font-size: 0.9rem; color: var(--text-muted); }
    .sl-price-cta { text-align: center; padding: 0 28px 32px; }

    /* ── FAQ ── */
    .sl-faq-list { max-width: 740px; margin: 50px auto 0; display: flex; flex-direction: column; gap: 14px; }
    .sl-faq-item {
      background: #fff;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
      transition: border-color 0.2s;
    }
    .sl-faq-item:hover { border-color: var(--brand); }
    .sl-faq-q {
      width: 100%; background: none; border: none; text-align: left;
      padding: 20px 24px; font-family: 'Inter', sans-serif;
      font-size: 0.97rem; font-weight: 700; color: var(--text-primary);
      cursor: pointer; display: flex; justify-content: space-between; align-items: center; gap: 12px;
    }
    .sl-faq-icon {
      width: 24px; height: 24px; border-radius: 999px;
      background: var(--brand-light); color: var(--brand);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.1rem; font-weight: 800; flex-shrink: 0;
      transition: background 0.2s, transform 0.2s;
    }
    .sl-faq-item.open .sl-faq-icon { background: var(--brand); color: #fff; transform: rotate(45deg); }
    .sl-faq-a {
      max-height: 0; overflow: hidden;
      transition: max-height 0.35s ease, padding 0.2s;
      font-size: 0.93rem; color: var(--text-secondary);
      padding: 0 24px; line-height: 1.7;
    }
    .sl-faq-item.open .sl-faq-a { max-height: 200px; padding: 0 24px 20px; }

    /* ── FINAL CTA ── */
    .sl-final-cta {
      background: linear-gradient(135deg, var(--brand) 0%, var(--accent) 100%);
      color: #fff; text-align: center; padding: 100px 24px;
    }
    .sl-final-cta .sl-title { color: #fff; }
    .sl-final-cta .sl-sub { color: rgba(255,255,255,0.85); margin: 0 auto 42px; }
    .sl-btn-white {
      display: inline-flex; align-items: center; gap: 8px;
      background: #fff; color: var(--brand); border: none;
      border-radius: 12px; padding: 18px 40px;
      font-size: 1.1rem; font-weight: 900; cursor: pointer;
      text-decoration: none;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      transition: transform 0.2s, box-shadow 0.2s; letter-spacing: -0.3px;
    }
    .sl-btn-white:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.3); color: var(--brand); }
    .sl-urgency {
      margin-top: 22px; font-size: 0.88rem; color: rgba(255,255,255,0.75);
      display: flex; align-items: center; justify-content: center; gap: 8px;
    }
    .sl-urgency-dot {
      width: 8px; height: 8px; background: #FCD34D;
      border-radius: 999px; animation: sl-pulse 1.4s ease-in-out infinite;
    }
    @keyframes sl-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.7); }
    }

    /* ── FOOTER ── */
    .sl-footer {
      background: var(--text-primary);
      color: rgba(255,255,255,0.45);
      text-align: center;
      padding: 28px 24px;
      font-size: 0.82rem;
      font-family: 'Inter', sans-serif;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .sl-receive-grid { grid-template-columns: 1fr; }
      .sl-steps-grid::before { display: none; }
      .sl-hero { padding: 70px 20px 60px; }
      .sl-section { padding: 70px 20px; }
    }
    @media (max-width: 480px) {
      .sl-trust-badges { flex-direction: column; align-items: center; }
      .sl-hero-actions { flex-direction: column; align-items: center; }
      .sl-btn-primary, .sl-btn-secondary { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>

  <!-- NAV -->
  <div class="sl-nav">
    <div class="sl-nav-inner">
      <span class="sl-nav-logo">⚡ ShopifyStore</span>
      <form action="/cart/add" method="post" style="margin:0;">
        <input type="hidden" name="id" value="{{ sl_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" class="sl-nav-cta">Get Store — $70</button>
      </form>
    </div>
  </div>

  <!-- HERO -->
  <div class="sl-hero">
    <div class="sl-hero-badge">
      <span>🔥</span> Only 3 Stores Available Today — Instant Delivery
    </div>
    <h1>Launch Your Own Digital&nbsp;Product Store Today — <em>No&nbsp;Experience&nbsp;Needed</em></h1>
    <p class="sl-hero-sub">
      Get a fully built Shopify store with 60 digital products, a premium custom theme, and a proven system that has already generated over <strong>$500,000 in sales</strong>.
    </p>
    <div class="sl-hero-actions">
      <form action="/cart/add" method="post" style="margin:0;">
        <input type="hidden" name="id" value="{{ sl_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" class="sl-btn-primary">
          🛒 Get Your Store Now — <strong>$70</strong>
        </button>
      </form>
      <a href="#sl-proof" class="sl-btn-secondary">
        📊 See Live Proof
      </a>
      <a href="https://psychoreads.com" class="sl-btn-secondary" target="_blank" rel="noopener" style="border-color:#059669;color:#059669;">
        👀 Preview the Live Store
      </a>
    </div>
    <!-- Scarcity alert -->
    <div style="display:inline-flex;align-items:center;gap:8px;background:#FEF2F2;border:1.5px solid #FCA5A5;border-radius:10px;padding:10px 20px;margin-bottom:32px;font-size:0.88rem;font-weight:700;color:#DC2626;">
      <span style="width:9px;height:9px;background:#EF4444;border-radius:50%;display:inline-block;animation:sl-pulse 1.2s ease-in-out infinite;"></span>
      Only 3 stores available today — once they're gone, this offer closes
    </div>
    <div class="sl-trust-badges">
      <div class="sl-badge"><span>🏆</span> 9 Years Experience</div>
      <div class="sl-badge"><span>💰</span> Proven Sales System</div>
      <div class="sl-badge"><span>⚡</span> Instant Delivery</div>
      <div class="sl-badge"><span>✅</span> $500k+ Generated</div>
    </div>
    <div class="sl-hero-img">
      <img
        src="https://cdn.shopify.com/s/files/1/0741/5070/7372/files/ChatGPTImage14mars2026_21_25_15.png?v=1773523539"
        alt="Shopify digital products store overview — proven $500k sales system"
        loading="eager"
      />
    </div>
  </div>

  <!-- PROOF -->
  <div class="sl-section sl-proof" id="sl-proof">
    <div class="sl-section-inner">
      <div class="sl-proof-header">
        <div class="sl-label">Proof</div>
        <h2 class="sl-title">Real Store. Real Sales. Proven System.</h2>
        <p class="sl-sub" style="margin:0 auto;text-align:center;">Numbers don't lie. Here's what this exact system has produced — no editing, no staging.</p>
      </div>
      <div class="sl-proof-grid">
        <div class="sl-proof-card">
          <img src="https://cdn.shopify.com/s/files/1/0741/5070/7372/files/Screenshot_2026-03-14_at_21.01.55.png?v=1773522205" alt="Stripe revenue screenshot showing real payment revenue" loading="lazy" />
          <div class="sl-proof-caption">Real payment revenue from the system</div>
        </div>
        <div class="sl-proof-card">
          <img src="https://cdn.shopify.com/s/files/1/0741/5070/7372/files/Screenshot_2026-03-14_at_21.06.13.png?v=1773522434" alt="Shopify analytics showing high conversion rate" loading="lazy" />
          <div class="sl-proof-caption">Conversion rate achieved in one day without ads</div>
