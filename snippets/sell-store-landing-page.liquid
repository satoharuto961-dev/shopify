  <script>
    // FAQ Toggle
    function slToggleFaq(btn) {
      const item = btn.closest('.sl-faq-item');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.sl-faq-item.open').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    }

    // ROI Calculator
    const slider = document.getElementById('roi-slider');
    const display = document.getElementById('slider-val-display');
    const daily = document.getElementById('calc-daily');
    const monthly = document.getElementById('calc-monthly');
    const AOV = 20; // $20 Average Order Value

    function updateRoi() {
      const sales = parseInt(slider.value);
      display.textContent = sales + " sales / day";
      
      const dailyEarn = sales * AOV;
      const monthlyEarn = dailyEarn * 30;
      
      daily.textContent = "$" + dailyEarn.toLocaleString();
      monthly.textContent = "$" + monthlyEarn.toLocaleString();
    }
    
    if(slider) {
      slider.addEventListener('input', updateRoi);
      updateRoi(); // Init
    }

    // Countdown Timer logic (Randomize start or fixed 4 hours)
    let time = 4 * 3600 + 28 * 60 + 59; // 4:28:59
    const hEl = document.getElementById('cd-h');
    const mEl = document.getElementById('cd-m');
    const sEl = document.getElementById('cd-s');
    
    if(hEl) {
      setInterval(() => {
        if(time > 0) time--;
        const h = Math.floor(time / 3600);
        const m = Math.floor((time % 3600) / 60);
        const s = time % 60;
        hEl.textContent = h.toString().padStart(2, '0');
        mEl.textContent = m.toString().padStart(2, '0');
        sEl.textContent = s.toString().padStart(2, '0');
      }, 1000);
    }

    // Sticky CTA logic
    const stickyCta = document.getElementById('sticky-cta');
    const heroBtn = document.getElementById('hero-btn');
    
    window.addEventListener('scroll', () => {
      if(!stickyCta || !heroBtn) return;
      const heroBottom = heroBtn.getBoundingClientRect().bottom;
      // Show sticky CTA once the hero button is scrolled out of view upwards
      if (heroBottom < 0) {
        stickyCta.classList.add('visible');
      } else {
        stickyCta.classList.remove('visible');
      }
    });

    // Smooth scroll
    document.querySelectorAll('a[href^="#sl-"]').forEach(a => {
      a.addEventListener('click', e => {
        const id = a.getAttribute('href').slice(1);
        const el = document.getElementById(id);
        if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });

    // Scroll animations
    const slObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.sl-feature-item, .sl-proof-card, .sl-why-card, .sl-bundle-item, .sl-faq-item, .sl-review-card').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
      slObserver.observe(el);
    });
  </script>

