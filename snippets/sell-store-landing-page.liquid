  <script>
    function slToggleFaq(btn) {
      const item = btn.closest('.sl-faq-item');
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.sl-faq-item.open').forEach(el => el.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    }

    // Smooth scroll
    document.querySelectorAll('a[href^="#sl-"]').forEach(a => {
      a.addEventListener('click', e => {
        const id = a.getAttribute('href').slice(1);
        const el = document.getElementById(id);
        if (el) { e.preventDefault(); el.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
      });
    });

    // Scroll animations
    const slObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.sl-feature-item, .sl-proof-card, .sl-why-card, .sl-step, .sl-faq-item').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
      slObserver.observe(el);
    });
  </script>

