{% assign bundle_handles = "emotion-in-posttraumatic-stress-disorder-etiology-assessment-neurobiology-and-treatment,emdr-and-attachment-focused-trauma-therapy-for-adults-reclaiming-authentic-self-and-healthy-attachments,transformational-chairwork-using-psychotherapeutic-dialogues-in-clinical-practice,pattern-focused-therapy-highly-effective-cbt-practice-in-mental-health-and-integrated-care-settings-first-edition,evidence-based-counselling-psychotherapy-for-the-21st-century-practitioner" | split: "," %}

{% comment %} 
  Override bundle_price to exactly $19.99 (1999 in cents) 
  But keep calculating the total_compare_price to show accurate savings
{% endcomment %}
{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}

{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

<style>
  /* Base Styles */
  .at-landing-page {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: #e2e8f0; /* Light gray text for dark theme */
    line-height: 1.6;
    background-color: #0f172a; /* Deep charcoal/navy background */
    padding-bottom: 100px;
  }
  
  .at-container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  
  .at-section {
    padding: 4rem 0;
  }

  /* Typography */
  h1, h2, h3 { line-height: 1.2; font-weight: 800; color: #f8fafc; }
  h2 { font-size: 2.25rem; margin-bottom: 2rem; text-align: center; }
  h3 { font-size: 1.5rem; margin-bottom: 1rem; color: #f1f5f9; }
  p { font-size: 1.125rem; color: #cbd5e1; margin-bottom: 1.5rem; }

  /* Hero Section */
  .at-hero {
    text-align: center;
    padding: 5rem 1rem 3rem;
    background: radial-gradient(circle at top, #1e293b 0%, #0f172a 100%);
    border-bottom: 1px solid #334155;
  }
  
  .at-hero-title {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
    color: #f8fafc;
  }
  
  .at-hero-subtitle {
    font-size: 1.5rem;
    max-width: 800px;
    margin: 0 auto 3rem;
    color: #94a3b8;
  }
  
  .at-books-display {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }
  
  .at-book-wrapper {
    width: 150px;
    position: relative;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  
  .at-book-wrapper:hover {
    transform: translateY(-15px) scale(1.05);
    z-index: 10;
  }
  
  .at-book-cover {
    width: 100%;
    height: auto;
    border-radius: 6px;
    box-shadow: -15px 15px 30px rgba(0,0,0,0.6), inset 2px 0 5px rgba(255,255,255,0.2);
  }

  /* Button Styles */
  .at-btn-container {
    text-align: center;
    margin: 2rem 0;
  }

  .at-btn {
    display: inline-block;
    background: linear-gradient(to right, #0d9488, #0f766e); /* Clinical deep teal */
    color: white;
    font-size: 1.5rem;
    font-weight: 800;
    padding: 1.25rem 3rem;
    border-radius: 100px;
    text-decoration: none;
    transition: all 0.2s ease;
    border: none;
    cursor: pointer;
    box-shadow: 0 10px 25px -5px rgba(13, 148, 136, 0.4);
    width: 100%;
    max-width: 500px;
  }
  
  .at-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -10px rgba(13, 148, 136, 0.6);
    color: white;
  }

  .at-btn-subtext {
    display: block;
    font-size: 0.875rem;
    color: #64748b;
    margin-top: 1rem;
    font-weight: 600;
  }

  /* The Problem/Solution Block */
  .at-thesis {
    background: #1e293b; /* Slightly lighter slate */
    border-radius: 24px;
    padding: 4rem 3rem;
    margin-top: -3rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    position: relative;
    z-index: 20;
    border: 1px solid #334155;
  }

  .at-thesis p {
    font-size: 1.25rem;
  }

  /* Book Breakdown Grid */
  .at-breakdown-card {
    display: grid;
    grid-template-columns: 1fr 3fr;
    gap: 3rem;
    background: #1e293b;
    padding: 3rem;
    border-radius: 24px;
    margin-bottom: 2rem;
    align-items: center;
    border: 1px solid #334155;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .at-breakdown-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px -10px rgba(0, 0, 0, 0.4);
    border-color: #475569;
  }

  .at-breakdown-img {
    width: 100%;
    max-width: 200px;
    margin: 0 auto;
    display: block;
    border-radius: 6px;
    box-shadow: -8px 8px 16px rgba(0,0,0,0.4);
  }

  .at-book-tag {
    display: inline-block;
    padding: 0.25rem 1rem;
    background: #134e4a; /* Dark teal background */
    color: #5eead4; /* Bright teal text */
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.875rem;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .at-checklist {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0 0;
  }

  .at-checklist li {
    position: relative;
    padding-left: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.125rem;
    color: #cbd5e1;
  }

  .at-checklist li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #2dd4bf; /* Bright teal checkmark */
    font-weight: 900;
  }

  /* Pricing Section */
  .at-pricing-hero {
    background: #020617; /* Pure black/slate */
    color: white;
    border-radius: 24px;
    padding: 4rem 2rem;
    text-align: center;
    margin: 4rem 0;
    border: 1px solid #1e293b;
  }

  .at-pricing-hero h2 { color: white; }
  .at-pricing-hero p { color: #94a3b8; }

  .at-price-block { margin: 2rem 0; }
  .at-price-current { font-size: 4rem; font-weight: 900; color: white; line-height: 1; }
  .at-price-original { font-size: 1.5rem; color: #64748b; text-decoration: line-through; margin-left: 1rem; }
  
  .at-savings-badge {
    display: inline-flex;
    align-items: center;
    background: #0d9488;
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    font-size: 1rem;
    font-weight: 800;
    margin-top: 1.5rem;
  }

  /* Social Proof */
  .at-reviews {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .at-review-card {
    background: #1e293b;
    padding: 2rem;
    border-radius: 16px;
    border: 1px solid #334155;
  }

  .at-stars { color: #5eead4; font-size: 1.25rem; margin-bottom: 1rem; }
  .at-review-text { font-style: italic; font-size: 1.125rem; margin-bottom: 1.5rem; color: #e2e8f0; }
  .at-review-author { font-weight: 700; color: #f8fafc; }

  /* Trust Icons */
  .at-trust-icons {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }
  
  .at-trust-icon {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #64748b;
    font-weight: 600;
    font-size: 0.875rem;
  }

  /* Sticky Footer */
  .at-sticky-form { margin: 0; }
  .at-sticky-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: #0f172a;
    padding: 1rem;
    box-shadow: 0 -10px 30px rgba(0,0,0,0.5);
    z-index: 50;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    border-top: 1px solid #334155;
  }
  
  .at-sticky-bar.visible { transform: translateY(0); }
  .at-sticky-title { font-weight: 800; font-size: 1.125rem; display: none; color: #f8fafc; }
  .at-sticky-price { font-weight: 900; font-size: 1.5rem; color: #2dd4bf; }

  @media (min-width: 1024px) {
    .at-sticky-title { display: block; }
  }

  @media (max-width: 768px) {
    .at-hero-title { font-size: 2.5rem; }
    .at-hero-subtitle { font-size: 1.25rem; }
    .at-thesis { padding: 2rem 1.5rem; margin-top: -2rem; }
    .at-breakdown-card { grid-template-columns: 1fr; gap: 2rem; text-align: center; padding: 2rem 1.5rem; }
    .at-checklist li { text-align: left; }
    .at-books-display { gap: 0.5rem; }
    .at-book-wrapper { width: 110px; }
  }
</style>

