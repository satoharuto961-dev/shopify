            <div class="at-book-wrapper">
              <img src="{{ current_product.featured_image | img_url: '400x' }}" alt="{{ current_product.title }}" class="at-book-cover">
            </div>
          {% endif %}
        {% endfor %}
      </div>
      
      <div class="at-btn-container">
        <a href="#checkout-section" class="at-btn" style="display:inline-block; max-width:400px; padding:1.25rem 2rem;">Claim The Library →</a>
