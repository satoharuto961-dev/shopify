{% comment %}
  Shared Styles, UI Components, and Logic for PsychoReads
{% endcomment %}

<style>
  /* ── Page Shell ── */
  .shop-page {
    background: #f8fafc;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ── Hero Banner ── */
  .shop-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f3460 100%);
    padding: 56px 24px 48px;
    text-align: center;
    color: #fff;
  }
  .shop-hero h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 16px;
    letter-spacing: -0.03em;
  }
  .shop-hero h1 span { color: #f59e0b; }
  .shop-hero p {
    font-size: 1.1rem;
    color: #94a3b8;
    max-width: 580px;
    margin: 0 auto 32px;
    line-height: 1.6;
  }
  .hero-offers {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
  }
  .hero-offer-pill {
    background: rgba(245,158,11,0.15);
    border: 1.5px solid #f59e0b;
    color: #fcd34d;
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-offer-pill em { color: #fff; font-style: normal; }

  /* ── Grid ── */
  .shop-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 48px 24px 120px;
  }
  .section-label {
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 24px;
  }
  .product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  @media (max-width: 1200px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 900px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px)  { .product-grid { grid-template-columns: 1fr; } }

  /* ── Card ── */
  .book-card {
    background: #fff;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(15,23,42,0.07);
    transition: transform 0.35s cubic-bezier(0.19,1,0.22,1), box-shadow 0.35s cubic-bezier(0.19,1,0.22,1);
    display: flex;
    flex-direction: column;
  }
  .book-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(15,23,42,0.16);
  }
  .book-card__img-wrap {
    position: relative;
    width: 100%;
    padding-top: 140%;
    overflow: hidden;
    background: #f1f5f9;
  }
  .book-card__img-wrap img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 12px;
    transition: transform 0.5s ease;
  }
  .book-card:hover .book-card__img-wrap img { transform: scale(1.05); }

  /* Adjust cover fit on mobile so it doesn't get clipped */
  @media (max-width: 540px) {
    .book-card__img-wrap {
      padding-top: 125%; /* Slightly shorter ratio */
    }
    .book-card__img-wrap img {
      object-fit: contain; /* Prevents edges from getting cut off */
      padding: 12px;
    }
  }
  
  /* ── Description Overlay ── */
  .book-card__desc-overlay {
    position: absolute;
    inset: 0;
    background: rgba(15, 23, 42, 0.85); /* Dark slate overlay */
    color: #fff;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    flex-direction: column;
    justify-content: center;
    backdrop-filter: blur(4px);
  }
  .book-card__img-wrap:hover .book-card__desc-overlay {
    opacity: 1;
  }
  .book-card__desc-text {
    font-size: 0.9rem;
    line-height: 1.5;
    font-weight: 500;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 8;
    overflow: hidden;
    text-shadow: 0 2px 4px rgba(0,0,0,0.5);
  }

  .book-card__badge {
    position: absolute;
    top: 12px;
    left: 12px;
    background: #0f172a;
    color: #f59e0b;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 4px;
  }
  .book-card__body {
    padding: 20px 20px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .book-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #0f172a;
    line-height: 1.35;
    margin-bottom: 8px;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    text-decoration: none;
  }
  .book-card__title:hover { color: #4f46e5; }
  .book-card__stars {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 12px;
  }
  .book-card__stars .stars { color: #f59e0b; font-size: 0.8rem; }
  .book-card__stars .count { font-size: 0.73rem; color: #94a3b8; }
  .book-card__price {
    font-size: 1.1rem;
    font-weight: 900;
    color: #0f172a;
    margin-bottom: 16px;
    margin-top: auto;
  }
  .book-card__price .compare { text-decoration: line-through; color: #94a3b8; font-weight: 400; font-size: 0.85rem; margin-left: 6px; }
  
  /* ── Social Proof Badge ── */
  .book-card__social-proof {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #dcfce7; /* Light green */
    color: #166534; /* Dark green */
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    margin-bottom: 16px;
    align-self: flex-start;
    transition: opacity 0.3s ease;
  }
  .book-card__social-proof.updating { opacity: 0.5; }
  .book-card__social-proof svg { width: 12px; height: 12px; opacity: 0.8; }
  .js-cart-count { transition: all 0.3s ease; }

  /* ── Add to Cart Button ── */
  .btn-atc {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 12px 16px;
    background: #0f172a;
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    font-family: inherit;
  }
  .btn-atc:hover:not(:disabled) { background: #1e3a8a; }
  .btn-atc:active:not(:disabled) { transform: scale(0.97); }
  .btn-atc:disabled { background: #94a3b8; cursor: not-allowed; }
  .btn-atc.state-adding { background: #4f46e5; }
  .btn-atc.state-added  { background: #059669; }

  /* ── Cart Drawer ── */
  .cd-overlay {
    position: fixed; inset: 0;
    background: rgba(15,23,42,0.5);
    backdrop-filter: blur(3px);
    z-index: 9000;
    opacity: 0; pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .cd-overlay.open { opacity: 1; pointer-events: auto; }

  .cd-panel {
    position: fixed; top: 0; right: 0; bottom: 0;
    width: min(420px, 100vw);
    background: #fff;
    z-index: 9001;
    display: flex; flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.38s cubic-bezier(0.19,1,0.22,1);
    box-shadow: -8px 0 40px rgba(15,23,42,0.18);
  }
  .cd-panel.open { transform: translateX(0); }

  .cd-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px 24px;
    border-bottom: 1px solid #e2e8f0;
    background: #0f172a;
    color: #fff;
  }
  .cd-header h2 { font-size: 1.1rem; font-weight: 800; margin: 0; display: flex; align-items: center; gap: 8px; }
  .cd-count-badge {
    background: #f59e0b; color: #0f172a;
    border-radius: 999px; font-size: 0.7rem; font-weight: 900;
    min-width: 20px; height: 20px; display: inline-flex;
    align-items: center; justify-content: center; padding: 0 5px;
  }
  .cd-close {
    background: rgba(255,255,255,0.1); border: none; color: #fff;
    width: 36px; height: 36px; border-radius: 50%; cursor: pointer;
    font-size: 1.2rem; display: flex; align-items: center; justify-content: center;
    transition: background 0.2s;
  }
  .cd-close:hover { background: rgba(255,255,255,0.2); }

  .cd-offers {
    display: flex; gap: 8px; padding: 12px 24px;
    background: #fffbeb; border-bottom: 1px solid #fde68a;
    overflow-x: auto; scrollbar-width: none;
  }
  .cd-offers::-webkit-scrollbar { display: none; }
  .cd-offer-pill {
    flex-shrink: 0;
    background: #f59e0b; color: #0f172a;
    border-radius: 999px; padding: 4px 12px;
    font-size: 0.72rem; font-weight: 800; white-space: nowrap;
  }

  .cd-items { flex: 1; overflow-y: auto; padding: 16px 24px; }
  .cd-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    height: 100%; color: #94a3b8; gap: 12px; text-align: center;
  }
  .cd-empty svg { width: 56px; height: 56px; opacity: 0.3; }

  .cd-item {
    display: flex; gap: 14px; padding: 14px 0;
    border-bottom: 1px solid #f1f5f9; align-items: flex-start;
  }
  .cd-item img {
    width: 70px; height: 95px; object-fit: cover;
    border-radius: 8px; flex-shrink: 0;
    border: 1px solid #e2e8f0;
  }
  .cd-item__info { flex: 1; min-width: 0; }
  .cd-item__title { font-size: 0.85rem; font-weight: 700; color: #0f172a; margin-bottom: 4px; line-height: 1.3; }
  .cd-item__price { font-size: 0.9rem; font-weight: 800; color: #4f46e5; margin-bottom: 8px; }
  .cd-item__qty {
    display: flex; align-items: center; gap: 8px;
  }
  .cd-item__qty button {
    width: 28px; height: 28px; border-radius: 50%;
    border: 1.5px solid #e2e8f0; background: #f8fafc;
    font-size: 1rem; font-weight: 700; cursor: pointer; color: #0f172a;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.15s;
  }
  .cd-item__qty button:hover { background: #0f172a; color: #fff; border-color: #0f172a; }
  .cd-item__qty span { font-size: 0.9rem; font-weight: 700; min-width: 20px; text-align: center; }
  .cd-item__remove { background: none; border: none; color: #94a3b8; cursor: pointer; font-size: 1.1rem; padding: 4px; }
  .cd-item__remove:hover { color: #dc2626; }

  .cd-footer {
    padding: 20px 24px;
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .cd-subtotal {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 16px;
  }
  .cd-subtotal span { font-size: 0.9rem; color: #64748b; }
  .cd-subtotal strong { font-size: 1.2rem; font-weight: 900; color: #0f172a; }
  .cd-checkout-btn {
    display: block; width: 100%; padding: 16px;
    background: linear-gradient(135deg, #4f46e5, #7c3aed);
    color: #fff; border: none; border-radius: 14px;
    font-size: 1rem; font-weight: 800; cursor: pointer;
    text-align: center; text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
    font-family: inherit;
  }
  .cd-checkout-btn:hover { opacity: 0.9; transform: scale(1.01); }
  .cd-cart-link {
    display: block; text-align: center; margin-top: 12px;
    color: #64748b; font-size: 0.85rem; text-decoration: underline; cursor: pointer;
    background: none; border: none; font-family: inherit; width: 100%;
  }
  .cd-cart-link:hover { color: #0f172a; }

  /* ── Sticky Add to Cart Bar ── */
  .sticky-atc-bar {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: #0f172a;
    padding: 14px 80px 14px 24px;
    z-index: 8000;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
    box-shadow: 0 -8px 32px rgba(15,23,42,0.3);
    transition: transform 0.4s cubic-bezier(0.19,1,0.22,1);
  }
  .sticky-atc-bar__left { display: flex; align-items: center; gap: 12px; min-width: 0; }
  .sticky-atc-bar__left img { width: 44px; height: 60px; object-fit: cover; border-radius: 6px; flex-shrink: 0; }
  .sticky-atc-bar__info { min-width: 0; }
  .sticky-atc-bar__title { font-size: 0.85rem; font-weight: 700; color: #fff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 180px; }
  .sticky-atc-bar__price { font-size: 0.9rem; font-weight: 800; color: #f59e0b; }
  .sticky-atc-bar__right { display: flex; align-items: center; gap: 10px; flex-shrink: 0; }
  .sticky-bar-atc {
    background: #f59e0b; color: #0f172a;
    border: none; border-radius: 10px;
    padding: 11px 20px; font-size: 0.9rem; font-weight: 800;
    cursor: pointer; transition: background 0.2s, transform 0.15s;
    font-family: inherit; white-space: nowrap;
  }
  .sticky-bar-atc:hover { background: #fbbf24; }
  .sticky-bar-atc:active { transform: scale(0.97); }
  .sticky-cart-btn {
    background: rgba(255,255,255,0.1); color: #fff;
    border: 1.5px solid rgba(255,255,255,0.2);
    border-radius: 10px; padding: 9px 14px;
    font-size: 0.85rem; font-weight: 700; cursor: pointer;
    display: flex; align-items: center; gap: 6px;
    transition: background 0.2s; font-family: inherit; white-space: nowrap;
  }
  .sticky-cart-btn:hover { background: rgba(255,255,255,0.2); }
  .sticky-cart-btn .cart-bubble {
    background: #f59e0b; color: #0f172a;
    border-radius: 999px; font-size: 0.65rem; font-weight: 900;
    min-width: 18px; height: 18px;
    display: inline-flex; align-items: center; justify-content: center; padding: 0 4px;
  }

  /* ── Toast Notification ── */
  .hp-toast {
    position: fixed; bottom: 90px; left: 50%; transform: translateX(-50%) translateY(20px);
    background: #059669; color: #fff;
    padding: 12px 24px; border-radius: 999px;
    font-size: 0.9rem; font-weight: 700;
    box-shadow: 0 8px 32px rgba(5,150,105,0.4);
    z-index: 9999;
    opacity: 0; pointer-events: none;
    transition: opacity 0.25s, transform 0.25s;
    white-space: nowrap;
  }
  .hp-toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>

<!-- ── Cart Drawer Overlay ── -->
<div class="cd-overlay" id="cdOverlay"></div>

<!-- ── Cart Drawer Panel ── -->
<div class="cd-panel" id="cdPanel" role="dialog" aria-label="Shopping cart" aria-modal="true">
  <div class="cd-header">
    <h2>🛒 Your Cart <span class="cd-count-badge" id="cdCountBadge">0</span></h2>
    <button class="cd-close" id="cdClose" aria-label="Close cart">✕</button>
  </div>
  <div class="cd-offers">
    <span class="cd-offer-pill">🎁 Limited-time price drop! $4 Sale → Minimum order 5 books</span>
  </div>
  <div class="cd-items" id="cdItems">
    <div class="cd-empty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      <p>Your cart is empty</p>
    </div>
  </div>
  <div class="cd-footer" id="cdFooter" style="display:none;">
    <div class="cd-subtotal">
      <span>Subtotal</span>
      <strong id="cdSubtotal">$0.00</strong>
    </div>
    
    <div id="cdMinimumWarning" style="display:none; text-align: center; margin-bottom: 15px; padding: 10px; background: #fee2e2; border: 1px solid #fecaca; border-radius: 8px;">
      <p style="color: #b91c1c; font-weight: 700; margin: 0; font-size: 0.85rem;">Minimum order is 5 products.</p>
    </div>

    <button class="cd-checkout-btn" id="cdCheckoutBtn" onclick="window.location='/checkout'">
      ✦ Checkout Securely
    </button>
    <button class="cd-cart-link" onclick="window.location='/cart'">View full cart</button>
  </div>
</div>

<!-- ── Toast ── -->
<div class="hp-toast" id="hpToast">✓ Added to cart!</div>

<!-- ── Sticky Bar ── -->
<div class="sticky-atc-bar" id="stickyAtcBar">
  <div class="sticky-atc-bar__left">
    <img src="" alt="" id="stickyImg" style="display:none;">
    <div class="sticky-atc-bar__info">
      <div class="sticky-atc-bar__title" id="stickyTitle"></div>
      <div class="sticky-atc-bar__price" id="stickyPrice"></div>
    </div>
  </div>
  <div class="sticky-atc-bar__right">
    <button class="sticky-cart-btn" onclick="HPCart.open()">
      🛒 Cart <span class="cart-bubble" id="stickyCartBubble">0</span>
    </button>
    <button class="sticky-bar-atc" id="stickyAtcBtn" style="display:none;" onclick="HPCart.buyLastItemNow()">
      + Checkout
    </button>
  </div>
</div>

<script>
(function() {
  'use strict';

  /* ── Tiny money formatter ── */
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  /* ── Toast ── */
  function showToast(msg) {
    var t = document.getElementById('hpToast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, 2800);
  }

  /* ── Cart State ── */
  var HPCart = {
    _lastBtn: null,
    _lastVariantId: null,

    /* Open / Close */
    open: function() {
      document.getElementById('cdPanel').classList.add('open');
      document.getElementById('cdOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
      HPCart.refresh();
    },
    close: function() {
      document.getElementById('cdPanel').classList.remove('open');
      document.getElementById('cdOverlay').classList.remove('open');
      document.body.style.overflow = '';
    },

    /* Refresh cart contents from Shopify */
    refresh: function() {
      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(cart){ HPCart.renderCart(cart); })
        .catch(function(){ });
    },

    /* Render items in drawer */
    renderCart: function(cart) {
      var count = cart.item_count;
      var itemsEl = document.getElementById('cdItems');
      var footerEl = document.getElementById('cdFooter');
      var badgeEl  = document.getElementById('cdCountBadge');
      var bubbleEl = document.getElementById('stickyCartBubble');

      /* Update count badges */
      badgeEl.textContent = count;
      bubbleEl.textContent = count;

      /* Update all theme cart counts */
      document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, .cart-item-count').forEach(function(el){
        el.textContent = count;
      });

      if (count === 0) {
        itemsEl.innerHTML = '<div class="cd-empty"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg><p>Your cart is empty</p></div>';
        footerEl.style.display = 'none';
        return;
      }

      footerEl.style.display = 'block';
      document.getElementById('cdSubtotal').textContent = formatMoney(cart.total_price);

      itemsEl.innerHTML = cart.items.map(function(item) {
        return '<div class="cd-item" data-key="' + item.key + '">' +
          '<img src="' + (item.image ? item.image.replace('_small','').replace('_medium','') + '&width=140' : '') + '" alt="' + item.title.replace(/"/g,'') + '" onerror="this.style.display=\'none\'">' +
          '<div class="cd-item__info">' +
            '<div class="cd-item__title">' + item.product_title + '</div>' +
            '<div class="cd-item__price">' + formatMoney(item.final_line_price) + '</div>' +
            '<div class="cd-item__qty">' +
              '<button onclick="HPCart.changeQty(\'' + item.key + '\',' + (item.quantity - 1) + ')">−</button>' +
              '<span>' + item.quantity + '</span>' +
              '<button onclick="HPCart.changeQty(\'' + item.key + '\',' + (item.quantity + 1) + ')">+</button>' +
              '<button class="cd-item__remove" title="Remove" onclick="HPCart.changeQty(\'' + item.key + '\',0)">🗑</button>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');

      /* Minimum order enforcement */
      var checkoutBtn = document.getElementById('cdCheckoutBtn');
      var warningEl  = document.getElementById('cdMinimumWarning');
      var stickyAtcBtn = document.getElementById('stickyAtcBtn');

      if (count < 5 && count > 0) {
        if (checkoutBtn) {
          checkoutBtn.disabled = true;
          checkoutBtn.style.opacity = '0.5';
          checkoutBtn.style.cursor = 'not-allowed';
        }
        if (warningEl) {
          warningEl.style.display = 'block';
        }
      } else {
        if (checkoutBtn) {
          checkoutBtn.disabled = false;
          checkoutBtn.style.opacity = '1';
          checkoutBtn.style.cursor = 'pointer';
        }
        if (warningEl) {
          warningEl.style.display = 'none';
        }
      }

      /* Sticky Bar Checkout Button Logic: 
         It adds 1 item, so it should be disabled if adding 1 still results in < 5 items (i.e. current count < 4).
      */
      if (stickyAtcBtn) {
        if (count < 4) {
          stickyAtcBtn.disabled = true;
          stickyAtcBtn.style.opacity = '0.5';
          stickyAtcBtn.style.cursor = 'not-allowed';
        } else {
          stickyAtcBtn.disabled = false;
          stickyAtcBtn.style.opacity = '1';
          stickyAtcBtn.style.cursor = 'pointer';
        }
      }
    },

    /* Change quantity */
    changeQty: function(key, qty) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty })
      })
      .then(function(r){ return r.json(); })
      .then(function(cart){ HPCart.renderCart(cart); });
    },

    /* Add to cart from card button */
    addToCart: function(btn) {
      var variantId = btn.getAttribute('data-variant-id');
      var title     = btn.getAttribute('data-title');
      var price     = btn.getAttribute('data-price');
      var img       = btn.getAttribute('data-img');
      HPCart._lastVariantId = variantId;
      HPCart._updateStickyBar(title, price, img, variantId);

      var orig = btn.innerHTML;
      btn.disabled = true;
      btn.classList.add('state-adding');
      btn.innerHTML = '⟳ Adding…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 
          'Content-Type': 'application/json', 
          'Accept': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(function(r){
        if (!r.ok) {
          return r.json().then(function(err){ 
            console.error('Shopify Add Error:', err);
            throw new Error(err.description || err.message || 'Cart add failed'); 
          });
        }
        return r.json();
      })
      .then(function() {
        btn.classList.remove('state-adding');
        btn.classList.add('state-added');
        btn.innerHTML = '✓ Added!';
        showToast('✓ "' + title + '" added to cart!');
        HPCart.refresh();
        setTimeout(function(){
          btn.classList.remove('state-added');
          btn.innerHTML = orig;
          btn.disabled = false;
        }, 2500);
      })
      .catch(function() {
        btn.classList.remove('state-adding');
        btn.innerHTML = orig;
        btn.disabled = false;
        /* Fallback to native form */
        fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'id=' + variantId + '&quantity=1'
        }).then(function(){ HPCart.refresh(); });
      });
    },

    /* Add last hovered item from sticky bar */
    addLastItem: function() {
      var id = HPCart._lastVariantId;
      if (!id) return;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function(r){ return r.json(); })
      .then(function() { HPCart.refresh(); showToast('✓ Added to cart!'); });
    },

    /* Buy last hovered item immediately (Checkout button) */
    buyLastItemNow: function() {
      var id = HPCart._lastVariantId;
      if (!id) {
        window.location = '/checkout';
        return;
      }
      
      var btn = document.getElementById('stickyAtcBtn');
      if (btn && btn.disabled) {
        HPCart.open(); // Open cart to show warning if they try to checkout with < 5
        return;
      }

      var orig = btn.innerHTML;
      btn.innerHTML = 'Loading...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function() { 
        // Must fetch full cart to get the total item_count
        return fetch('/cart.js', { headers: { 'Accept': 'application/json' } });
      })
      .then(function(r) { return r.json(); })
      .then(function(cart) {
        if (cart.item_count < 5) {
          window.location.href = '/cart';
        } else {
          window.location.href = '/checkout';
        }
      })
      .catch(function(){ window.location = '/cart'; });
    },

    /* Update sticky bar with last hovered book */
    _updateStickyBar: function(title, price, img, variantId) {
      document.getElementById('stickyTitle').textContent = title;
      document.getElementById('stickyPrice').textContent = price;
      var sImg = document.getElementById('stickyImg');
      if (img) { sImg.src = img; sImg.style.display = ''; }
      document.getElementById('stickyAtcBtn').style.display = '';
      HPCart._lastVariantId = variantId;
    }
  };

  /* ── Update sticky on card hover ── */
  function initCardHovers() {
    document.querySelectorAll('.book-card').forEach(function(card) {
      if (card.dataset.hoverBound) return;
      card.dataset.hoverBound = "true";
      card.addEventListener('mouseenter', function() {
        var title = card.getAttribute('data-product-title');
        var price = card.getAttribute('data-price');
        var img   = card.getAttribute('data-img');
        var vid   = card.getAttribute('data-variant-id');
        if (title) HPCart._updateStickyBar(title, price, img, vid);
      });
    });
  }

  /* ── Dynamic Social Proof Counts ── */
  function updateSocialProof() {
    var counts = document.querySelectorAll('.js-cart-count');
    counts.forEach(function(el) {
      var badge = el.closest('.book-card__social-proof');
      if (badge) badge.classList.add('updating');
      
      setTimeout(function() {
        var newCount = Math.floor(Math.random() * (25 - 7 + 1)) + 7;
        el.textContent = newCount;
        if (badge) badge.classList.remove('updating');
      }, 300);
    });
  }

  /* ── Close drawer ── */
  document.getElementById('cdClose').addEventListener('click', HPCart.close);
  document.getElementById('cdOverlay').addEventListener('click', HPCart.close);

  /* ── Init ── */
  HPCart.refresh();
  initCardHovers();
  setInterval(updateSocialProof, 7000);
  
  // Re-init hovers if content changes (for pagination/infinite scroll)
  document.addEventListener('shopify:section:load', initCardHovers);
  // MutationObserver as a fallback for dynamic grids
  var observer = new MutationObserver(initCardHovers);
  var grid = document.querySelector('.product-grid');
  if (grid) observer.observe(grid, { childList: true });

  /* Expose globally */
  window.HPCart = HPCart;
})();
</script>
