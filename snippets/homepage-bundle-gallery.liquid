{% comment %}
  =============================================================================
  HOMEPAGE PRODUCT GRID — All Books + Self-contained Cart Drawer + Sticky Bar
  =============================================================================
{% endcomment %}

<style>
  /* ── Page Shell ── */
  .shop-page {
    background: #f8fafc;
    min-height: 100vh;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  /* ── Featured Hero Product ── */
  .shop-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 60%, #0f3460 100%);
    color: #fff;
    padding: 60px 24px;
    position: relative;
    overflow: hidden;
  }
  .hero-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .hero-text {
    flex: 1;
  }
  .hero-badge {
    display: inline-block;
    background: #f59e0b;
    color: #0f172a;
    font-size: 0.75rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 6px 12px;
    border-radius: 999px;
    margin-bottom: 24px;
  }
  .hero-text h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    line-height: 1.05;
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }
  .hero-text p {
    font-size: 1.15rem;
    color: #cbd5e1;
    line-height: 1.6;
    margin-bottom: 32px;
    max-width: 500px;
  }
  .hero-offers {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 32px;
  }
  .hero-offer-pill {
    background: rgba(245,158,11,0.15);
    border: 1.5px solid #f59e0b;
    color: #fcd34d;
    border-radius: 999px;
    padding: 8px 20px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-offer-pill em { color: #fff; font-style: normal; }
  
  .hero-product {
    flex: 0 0 340px;
    position: relative;
  }
  .hero-product-inner {
    background: #fff;
    border-radius: 24px;
    padding: 24px;
    color: #0f172a;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
    transform: rotate(2deg);
    transition: transform 0.4s cubic-bezier(0.19,1,0.22,1);
  }
  .hero-product-inner:hover {
    transform: rotate(0deg) translateY(-8px);
  }
  .hero-book-img {
    width: 100%;
    border-radius: 12px;
    margin-bottom: 20px;
    box-shadow: 0 8px 24px rgba(15,23,42,0.15);
  }
  .hero-book-price { margin-bottom: 16px; font-size: 1.25rem; font-weight: 900; }
  .hero-book-price s { color: #94a3b8; font-weight: 500; font-size: 0.9rem; margin-left: 8px; }

  @media (max-width: 900px) {
    .hero-container { flex-direction: column; text-align: center; gap: 40px; }
    .hero-offers { justify-content: center; }
    .hero-text p { margin-left: auto; margin-right: auto; }
    .hero-product { flex: 0 0 auto; width: 100%; max-width: 380px; }
  }
</style>

<!-- ── Cart Drawer Overlay ── -->
<div class="cd-overlay" id="cdOverlay"></div>

<!-- ── Cart Drawer Panel ── -->
<div class="cd-panel" id="cdPanel" role="dialog" aria-label="Shopping cart" aria-modal="true">
  <div class="cd-header">
    <h2>🛒 Your Cart <span class="cd-count-badge" id="cdCountBadge">0</span></h2>
    <button class="cd-close" id="cdClose" aria-label="Close cart">✕</button>
  </div>
  <div class="cd-offers">
    <span class="cd-offer-pill">🎁 Buy 1 → Get 2 FREE</span>
    <span class="cd-offer-pill">🎁 Buy 2 → Get 5 FREE</span>
    <span class="cd-offer-pill">🎁 Buy 3 → Get 12 FREE</span>
  </div>
  <div class="cd-items" id="cdItems">
    <div class="cd-empty">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      <p>Your cart is empty</p>
    </div>
  </div>
  <div class="cd-footer" id="cdFooter" style="display:none;">
    <div class="cd-subtotal">
      <span>Subtotal</span>
      <strong id="cdSubtotal">$0.00</strong>
    </div>
    <button class="cd-checkout-btn" onclick="window.location='/checkout'">
      ✦ Checkout Securely
    </button>
    <button class="cd-cart-link" onclick="window.location='/cart'">View full cart</button>
  </div>
</div>

<!-- ── Toast ── -->
<div class="hp-toast" id="hpToast">✓ Added to cart!</div>

<!-- ── Sticky Bar ── -->
<div class="sticky-atc-bar" id="stickyAtcBar">
  <div class="sticky-atc-bar__left">
    <img src="" alt="" id="stickyImg" style="display:none;">
    <div class="sticky-atc-bar__info">
      <div class="sticky-atc-bar__title" id="stickyTitle"></div>
      <div class="sticky-atc-bar__price" id="stickyPrice"></div>
    </div>
  </div>
  <div class="sticky-atc-bar__right">
    <button class="sticky-cart-btn" onclick="HPCart.open()">
      🛒 Cart <span class="cart-bubble" id="stickyCartBubble">0</span>
    </button>
    <button class="sticky-bar-atc" id="stickyAtcBtn" style="display:none;" onclick="HPCart.buyLastItemNow()">
      + Checkout
    </button>
  </div>
</div>

<!-- ── Page Content ── -->
<div class="shop-page">

  <!-- Hero -->
  {% assign hero_book = all_products['the-body-keeps-the-score-brain-mind-and-body-in-the-healing-of-trauma'] %}
  {% if hero_book == empty or hero_book == blank %}
    {% assign hero_book = all_products['the-body-keeps-the-score'] %}
  {% endif %}

  <div class="shop-hero">
    <div class="hero-container">
      <div class="hero-text">
        <span class="hero-badge">New Arrival</span>
        <h1>The Body Keeps <span style="color:#f59e0b;">The Score.</span></h1>
        <p>Bessel van der Kolk's pioneering work on trauma and healing. Discover how traumatic stress reshapes the brain and body—and how we can heal.</p>
        
        <div class="hero-offers">
          <div class="hero-offer-pill">🎁 Buy <em>1</em> → Get <em>2 Free</em></div>
          <div class="hero-offer-pill">🎁 Buy <em>2</em> → Get <em>5 Free</em></div>
          <div class="hero-offer-pill">🎁 Buy <em>3</em> → Get <em>12 Free</em></div>
        </div>
      </div>

      {% if hero_book and hero_book != empty %}
        {% assign hero_variant = hero_book.first_available_variant | default: hero_book.variants.first %}
        <div class="hero-product">
          <div class="hero-product-inner">
            <a href="{{ hero_book.url }}">
              <img src="{{ hero_book.featured_image | img_url: '600x600', crop: 'center' }}" alt="{{ hero_book.title }}" class="hero-book-img">
            </a>
            <div class="hero-book-price">
              {{ hero_variant.price | money }}
              {% if hero_variant.compare_at_price > hero_variant.price %}
                <s>{{ hero_variant.compare_at_price | money }}</s>
              {% endif %}
            </div>
            <button
              class="btn-atc"
              data-variant-id="{{ hero_variant.id }}"
              data-title="{{ hero_book.title | escape }}"
              data-price="{{ hero_variant.price | money }}"
              data-img="{{ hero_book.featured_image | img_url: '200x280', crop: 'center' }}"
              onclick="HPCart.addToCart(this)">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
              Add to Cart
            </button>
          </div>
        </div>
      {% endif %}
    </div>
  </div>

  <!-- Grid -->
  <div class="shop-container">
    <p class="section-label">All Books — {{ collections.all.products_count }} titles</p>

    {% if collections.all.products.size > 0 %}
      <div class="product-grid">
        {% for product in collections.all.products limit: 100 %}
          {% assign variant = product.first_available_variant | default: product.variants.first %}
          <div class="book-card"
               data-product-title="{{ product.title | escape }}"
               data-variant-id="{{ variant.id }}"
               data-price="{{ variant.price | money }}"
               data-img="{{ product.featured_image | img_url: '200x280', crop: 'center' }}">

            <a href="{{ product.url }}" class="book-card__img-wrap">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | img_url: '600x900', crop: 'center' }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  loading="lazy">
              {% else %}
                <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;background:#e2e8f0;color:#94a3b8;font-size:0.8rem;">No image</div>
              {% endif %}
              
              <!-- Hover Description Overlay -->
              <div class="book-card__desc-overlay">
                <div class="book-card__desc-text">
                  {{ product.description | strip_html | truncatewords: 35 }}
                </div>
              </div>

              <span class="book-card__badge">Bundle</span>
            </a>

            <div class="book-card__body">
              <a href="{{ product.url }}" class="book-card__title">{{ product.title }}</a>
              <div class="book-card__stars">
                <span class="stars">★★★★★</span>
                <span class="count">(4.9)</span>
              </div>
              <div class="book-card__price">
                {{ variant.price | money }}
                {% if variant.compare_at_price > variant.price %}
                  <span class="compare">{{ variant.compare_at_price | money }}</span>
                {% endif %}
              </div>

              {% if variant.available %}
                <button
                  class="btn-atc"
                  data-variant-id="{{ variant.id }}"
                  data-title="{{ product.title | escape }}"
                  data-price="{{ variant.price | money }}"
                  data-img="{{ product.featured_image | img_url: '200x280', crop: 'center' }}"
                  onclick="HPCart.addToCart(this)">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" width="16" height="16"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                  Add to Cart
                </button>
              {% else %}
                <button class="btn-atc" disabled>Sold Out</button>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div style="text-align:center;padding:80px 24px;color:#64748b;">
        <p>No products found. Add products to your store to see them here.</p>
      </div>
    {% endif %}
  </div>
</div>

<script>
(function() {
  'use strict';

  /* ── Tiny money formatter ── */
  function formatMoney(cents) {
    return '$' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  /* ── Toast ── */
  function showToast(msg) {
    var t = document.getElementById('hpToast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(function(){ t.classList.remove('show'); }, 2800);
  }

  /* ── Cart State ── */
  var HPCart = {
    _lastBtn: null,
    _lastVariantId: null,

    /* Open / Close */
    open: function() {
      document.getElementById('cdPanel').classList.add('open');
      document.getElementById('cdOverlay').classList.add('open');
      document.body.style.overflow = 'hidden';
      HPCart.refresh();
    },
    close: function() {
      document.getElementById('cdPanel').classList.remove('open');
      document.getElementById('cdOverlay').classList.remove('open');
      document.body.style.overflow = '';
    },

    /* Refresh cart contents from Shopify */
    refresh: function() {
      fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
        .then(function(r){ return r.json(); })
        .then(function(cart){ HPCart.renderCart(cart); })
        .catch(function(){ });
    },

    /* Render items in drawer */
    renderCart: function(cart) {
      var count = cart.item_count;
      var itemsEl = document.getElementById('cdItems');
      var footerEl = document.getElementById('cdFooter');
      var badgeEl  = document.getElementById('cdCountBadge');
      var bubbleEl = document.getElementById('stickyCartBubble');

      /* Update count badges */
      badgeEl.textContent = count;
      bubbleEl.textContent = count;

      /* Update all theme cart counts */
      document.querySelectorAll('[data-cart-count], .cart-count, .cart__count, .cart-item-count').forEach(function(el){
        el.textContent = count;
      });

      if (count === 0) {
        itemsEl.innerHTML = '<div class="cd-empty"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg><p>Your cart is empty</p></div>';
        footerEl.style.display = 'none';
        return;
      }

      footerEl.style.display = 'block';
      document.getElementById('cdSubtotal').textContent = formatMoney(cart.total_price);

      itemsEl.innerHTML = cart.items.map(function(item) {
        return '<div class="cd-item" data-key="' + item.key + '">' +
          '<img src="' + (item.image ? item.image.replace('_small','').replace('_medium','') + '&width=140' : '') + '" alt="' + item.title.replace(/"/g,'') + '" onerror="this.style.display=\'none\'">' +
          '<div class="cd-item__info">' +
            '<div class="cd-item__title">' + item.product_title + '</div>' +
            '<div class="cd-item__price">' + formatMoney(item.final_line_price) + '</div>' +
            '<div class="cd-item__qty">' +
              '<button onclick="HPCart.changeQty(\'' + item.key + '\',' + (item.quantity - 1) + ')">−</button>' +
              '<span>' + item.quantity + '</span>' +
              '<button onclick="HPCart.changeQty(\'' + item.key + '\',' + (item.quantity + 1) + ')">+</button>' +
              '<button class="cd-item__remove" title="Remove" onclick="HPCart.changeQty(\'' + item.key + '\',0)">🗑</button>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    },

    /* Change quantity */
    changeQty: function(key, qty) {
      fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty })
      })
      .then(function(r){ return r.json(); })
      .then(function(cart){ HPCart.renderCart(cart); });
    },

    /* Add to cart from card button */
    addToCart: function(btn) {
      var variantId = btn.getAttribute('data-variant-id');
      var title     = btn.getAttribute('data-title');
      var price     = btn.getAttribute('data-price');
      var img       = btn.getAttribute('data-img');
      HPCart._lastVariantId = variantId;
      HPCart._updateStickyBar(title, price, img, variantId);

      var orig = btn.innerHTML;
      btn.disabled = true;
      btn.classList.add('state-adding');
      btn.innerHTML = '⟳ Adding…';

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(variantId, 10), quantity: 1 })
      })
      .then(function(r){
        if (!r.ok) throw new Error('Cart add failed');
        return r.json();
      })
      .then(function() {
        btn.classList.remove('state-adding');
        btn.classList.add('state-added');
        btn.innerHTML = '✓ Added!';
        showToast('✓ "' + title + '" added to cart!');
        HPCart.refresh();
        setTimeout(function(){
          btn.classList.remove('state-added');
          btn.innerHTML = orig;
          btn.disabled = false;
        }, 2500);
      })
      .catch(function() {
        btn.classList.remove('state-adding');
        btn.innerHTML = orig;
        btn.disabled = false;
        /* Fallback to native form */
        fetch('/cart/add', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'id=' + variantId + '&quantity=1'
        }).then(function(){ HPCart.refresh(); });
      });
    },

    /* Add last hovered item from sticky bar */
    addLastItem: function() {
      var id = HPCart._lastVariantId;
      if (!id) return;
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function(r){ return r.json(); })
      .then(function() { HPCart.refresh(); showToast('✓ Added to cart!'); });
    },

    /* Buy last hovered item immediately (Checkout button) */
    buyLastItemNow: function() {
      var id = HPCart._lastVariantId;
      if (!id) {
        window.location = '/checkout';
        return;
      }
      var btn = document.getElementById('stickyAtcBtn');
      var orig = btn.innerHTML;
      btn.innerHTML = 'Loading...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ id: parseInt(id, 10), quantity: 1 })
      })
      .then(function(){ window.location = '/checkout'; })
      .catch(function(){ window.location = '/checkout'; });
    },

    /* Update sticky bar with last hovered book */
    _updateStickyBar: function(title, price, img, variantId) {
      document.getElementById('stickyTitle').textContent = title;
      document.getElementById('stickyPrice').textContent = price;
      var sImg = document.getElementById('stickyImg');
      if (img) { sImg.src = img; sImg.style.display = ''; }
      document.getElementById('stickyAtcBtn').style.display = '';
      HPCart._lastVariantId = variantId;
    }
  };

  /* ── Sticky bar visibility on scroll ── */
  var stickyBar = document.getElementById('stickyAtcBar');
  var heroEl    = document.querySelector('.shop-hero');
  window.addEventListener('scroll', function() {
    if (!heroEl) return;
    var heroBottom = heroEl.getBoundingClientRect().bottom;
    if (heroBottom < 0) {
      stickyBar.classList.add('visible');
    } else {
      stickyBar.classList.remove('visible');
    }
  }, { passive: true });

  /* ── Update sticky on card hover ── */
  document.querySelectorAll('.book-card').forEach(function(card) {
    card.addEventListener('mouseenter', function() {
      var title = card.getAttribute('data-product-title');
      var price = card.getAttribute('data-price');
      var img   = card.getAttribute('data-img');
      var vid   = card.getAttribute('data-variant-id');
      if (title) HPCart._updateStickyBar(title, price, img, vid);
    });
  });

  /* ── Close drawer ── */
  document.getElementById('cdClose').addEventListener('click', HPCart.close);
  document.getElementById('cdOverlay').addEventListener('click', HPCart.close);

  /* ── Initial cart count ── */
  HPCart.refresh();

  /* Expose globally */
  window.HPCart = HPCart;
})();
</script>
