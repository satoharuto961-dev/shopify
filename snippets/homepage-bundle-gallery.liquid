{% comment %}
  =============================================================================
  HOMEPAGE BUNDLE GALLERY — Premium "Book Stack" Edition
  Clean & Balanced (Standardized Sizes + Enhanced Hover)
  =============================================================================
{% endcomment %}

<style>
  :root {
    --bg-main: #ffffff;
    --text-dark: #0f172a;
    --text-muted: #64748b;
  }

  .gallery-wrapper {
    background-color: var(--bg-main);
    padding: 60px 0 120px;
    font-family: 'Inter', -apple-system, sans-serif;
    overflow-x: hidden;
  }

  .gallery-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .gallery-intro {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 80px;
  }

  .gallery-intro h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    color: var(--text-dark);
    line-height: 1;
    margin-bottom: 24px;
    letter-spacing: -0.04em;
  }

  .gallery-intro p {
    font-size: 1.25rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Standardized Clean Grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr); /* 3 Columns for bigger cards */
    grid-auto-rows: 400px; /* Taller uniform cards */
    gap: 32px;
  }

  /* Card Base */
  .gallery-card {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.6s cubic-bezier(0.19, 1, 0.22, 1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 40px;
    z-index: 1;
  }

  .gallery-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 40px 80px -20px rgba(15, 23, 42, 0.35);
  }

  /* Stack Backgrounds */
  .bg-finance    { background: linear-gradient(135deg, #059669, #064e3b); }
  .bg-mastery    { background: linear-gradient(135deg, #2563eb, #1e3a8a); }
  .bg-classic    { background: linear-gradient(135deg, #d97706, #78350f); }
  .bg-clinical   { background: linear-gradient(135deg, #0d9488, #134e4a); }
  .bg-trauma     { background: linear-gradient(135deg, #dc2626, #7f1d1d); }
  .bg-dystopia   { background: linear-gradient(135deg, #4b5563, #111827); }
  .bg-timeless   { background: linear-gradient(135deg, #7c3aed, #4c1d95); }
  .bg-mystery    { background: linear-gradient(135deg, #db2777, #831843); }
  .bg-cultural   { background: linear-gradient(135deg, #4f46e5, #312e81); }
  .bg-final      { background: linear-gradient(135deg, #0891b2, #155e75); }
  .bg-clinical-ex { background: linear-gradient(135deg, #1e3a8a, #0f172a); }

  .gallery-card::after {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 60%);
    z-index: 2;
  }

  .card-content { position: relative; z-index: 10; transition: transform 0.6s ease; }
  .gallery-card:hover .card-content { transform: translateY(-10px); }

  .card-tag {
    font-size: 0.75rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: 0.15em; color: rgba(255, 255, 255, 0.7); margin-bottom: 8px; display: block;
  }
  .card-title { font-size: 2rem; font-weight: 900; color: white; margin-bottom: 4px; line-height: 1.1; }

  /* Book Stack Magic - Enhanced for visibility */
  .book-stack {
    position: absolute; right: 0; left: 0; top: 10%; 
    height: 220px; z-index: 3; pointer-events: none;
    display: flex; justify-content: center; align-items: center;
  }
  .book-item-layer {
    position: absolute; width: 130px; height: 190px; border-radius: 6px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.4); background-size: cover;
    background-position: center; transition: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
    border: 1px solid rgba(255,255,255,0.1);
  }

  /* Default Stacking */
  .layer-1 { z-index: 1; transform: rotate(-6deg) translateX(-30px); opacity: 0.85; }
  .layer-2 { z-index: 2; transform: rotate(-2deg) translateX(0); opacity: 0.95; }
  .layer-3 { z-index: 3; transform: rotate(4deg) translateX(30px); }

  /* Enhanced Fan-Out on Hover - Making all books VISIBLE */
  .gallery-card:hover .layer-1 { transform: rotate(-18deg) translateX(-110px) translateY(-15px); opacity: 1; }
  .gallery-card:hover .layer-2 { transform: rotate(0deg) translateX(0) translateY(-25px) scale(1.05); opacity: 1; }
  .gallery-card:hover .layer-3 { transform: rotate(18deg) translateX(110px) translateY(-15px); opacity: 1; }

  @media (max-width: 1200px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .gallery-grid { grid-template-columns: 1fr; grid-auto-rows: 350px; }
    .gallery-intro h1 { font-size: 2.5rem; }
    .book-stack { top: 10%; scale: 0.9; }
  }
</style>

