{% comment %}
  =============================================================================
  HOMEPAGE PRODUCT GRID — All Books + Self-contained Cart Drawer + Sticky Bar
  =============================================================================
{% endcomment %}

{% render 'shop-common' %}

<!-- ── Page Content ── -->
<div class="shop-page">

  <!-- Hero -->
  <div class="shop-hero">
    <h1>Build Your <span>Library.</span></h1>
    <p>Curated psychology &amp; self-improvement books. Grab more, save more — exclusive sale just for you.</p>
    <div class="hero-offers">
    </div>
  </div>

  <!-- Grid -->
  <div class="shop-container">
    <p class="section-label">All Books — {{ collections.frontpage.products_count }} titles</p>

    {% if collections.frontpage.products.size > 0 %}
      <div class="product-grid">
        {% paginate collections.frontpage.products by 1000 %}

        {% assign target_book = all_products['the-body-keeps-the-score-brain-mind-and-body-in-the-healing-of-trauma'] %}
        {% if target_book == empty or target_book == blank %}
          {% assign target_book = all_products['the-body-keeps-the-score'] %}
        {% endif %}
        
        {% if target_book and target_book != empty %}
          {% render 'book-card', product: target_book %}
        {% endif %}

        {% assign products_sorted = collections.frontpage.products %}
        {% for product in products_sorted limit: 1000 %}
          {% if target_book and product.handle == target_book.handle %}
            {% continue %}
          {% endif %}
          {% render 'book-card', product: product %}
        {% endfor %}
        
        {% endpaginate %}
      </div>
    {% else %}
      <div style="text-align:center;padding:80px 24px;color:#64748b;">
        <p>No products found. Add products to your store to see them here.</p>
      </div>
    {% endif %}
  </div>
</div>

