{% comment %}
  Therapy Toolkit Landing Page - Professional Edition
  Template: page.therapy-toolkit.liquid
  Product: ultimate-therapist-toolkit-1100-professional-therapy-resources
{% endcomment %}

{% assign tt = all_products['ultimate-therapist-toolkit-1100-professional-therapy-resources'] %}
{% assign tt_variant = tt.variants.first %}

<style>
  /* ── GLOBALS & RESET ── */
  .announce-bar, .site-header { display: none !important; }
  .tt-wrap * { box-sizing: border-box; }
  .tt-wrap {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    color: #1e293b;
    line-height: 1.6;
    background: #f8fafc;
    overflow-x: hidden;
  }
  
  /* ── TYPOGRAPHY & UTILS ── */
  .tt-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; width: 100%; }
  .tt-section { padding: 90px 0; }
  .tt-section-bg-white { background: #ffffff; }
  .tt-section-bg-dark { background: #0f172a; color: white; }
  .tt-text-center { text-align: center; }
  
  .tt-h2 {
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -0.02em;
    color: inherit;
  }
  
  .tt-p-lead {
    font-size: clamp(18px, 2vw, 22px);
    color: #475569;
    max-width: 720px;
    margin: 0 auto 40px;
    line-height: 1.6;
  }
  .tt-section-bg-dark .tt-p-lead { color: #94a3b8; }
  
  /* ── BUTTONS ── */
  .tt-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    background: #ff6b00;
    color: white !important;
    font-size: 20px;
    font-weight: 800;
    padding: 20px 48px;
    border-radius: 99px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 25px -5px rgba(255, 107, 0, 0.4);
    line-height: 1;
    width: auto;
  }
  .tt-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 30px -10px rgba(255, 107, 0, 0.5);
  }
  .tt-btn-full { width: 100%; }
  
  .tt-btn-subtext {
    display: block;
    text-align: center;
    font-size: 13px;
    color: #64748b;
    margin-top: 12px;
    font-weight: 500;
  }
  .tt-section-bg-dark .tt-btn-subtext { color: #64748b; }

  /* ── HERO SECTION ── */
  .tt-hero {
    position: relative;
    background: linear-gradient(145deg, #020617 0%, #0f172a 100%);
    color: white;
    padding: 120px 0 100px;
    text-align: center;
    overflow: hidden;
  }
  
  /* Background glow effect */
  .tt-hero::before {
    content: '';
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 1000px;
    height: 1000px;
    background: radial-gradient(circle, rgba(14, 165, 233, 0.15) 0%, rgba(255,255,255,0) 70%);
    pointer-events: none;
  }

  .tt-hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 8px 20px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 600;
    color: #e2e8f0;
    margin-bottom: 32px;
  }
  .tt-hero-badge span { color: #38bdf8; }

  .tt-hero h1 {
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -0.03em;
    max-width: 900px;
    margin: 0 auto 24px;
    background: linear-gradient(to right, #ffffff, #e2e8f0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .tt-hero p.tt-subtitle {
    font-size: clamp(18px, 2.5vw, 24px);
    color: #94a3b8;
    max-width: 760px;
    margin: 0 auto 48px;
    line-height: 1.5;
  }

  .tt-trust-indicators {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 32px;
    margin-top: 48px;
    flex-wrap: wrap;
  }
  .tt-trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #cbd5e1;
    font-size: 15px;
    font-weight: 500;
  }
  .tt-trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: rgba(14, 165, 233, 0.15);
    border-radius: 50%;
    color: #38bdf8;
  }

  /* ── SOCIAL PROOF BAR ── */
  .tt-proof-bar {
    background: white;
    border-bottom: 1px solid #e2e8f0;
    padding: 32px 0;
  }
  .tt-proof-grid {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 32px;
  }
  .tt-proof-stat { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .tt-proof-num { font-size: 36px; font-weight: 900; color: #0f172a; line-height: 1; }
  .tt-proof-label { font-size: 14px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; }
  .tt-proof-stars { color: #f59e0b; font-size: 20px; letter-spacing: 2px; }

  /* ── WHO IS THIS FOR (Professions) ── */
  .tt-professions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }
  .tt-profession-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
  }
  .tt-profession-card:hover {
    transform: translateY(-5px);
    border-color: #38bdf8;
    box-shadow: 0 20px 25px -5px rgba(14, 165, 233, 0.1);
  }
  .tt-prof-icon {
    width: 64px;
    height: 64px;
    background: #f0f9ff;
    color: #0284c7;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 28px;
    margin: 0 auto 20px;
  }
  .tt-prof-title { font-size: 18px; font-weight: 800; color: #0f172a; margin: 0; }

  /* ── PRODUCT SHOWCASE ── */
  .tt-showcase { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  
  /* Images */
  .tt-gallery { display: flex; flex-direction: column; gap: 16px; }
  .tt-gallery-main {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: contain;
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
    padding: 24px;
    border: 1px solid #e2e8f0;
    cursor: zoom-in;
  }
  .tt-gallery-thumbs { display: flex; gap: 12px; flex-wrap: wrap; }
  .tt-gallery-thumb {
    width: 80px;
    height: 80px;
    object-fit: contain;
    background: #ffffff;
    border-radius: 12px;
    border: 2px solid transparent;
    padding: 8px;
    cursor: pointer;
    transition: all 0.2s;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
  }
  .tt-gallery-thumb:hover, .tt-gallery-thumb.active { border-color: #38bdf8; transform: translateY(-2px); }

  /* Details */
  .tt-showcase-content { display: flex; flex-direction: column; gap: 24px; }
  .tt-tag {
    display: inline-flex;
    background: #eff6ff;
    color: #2563eb;
    padding: 6px 16px;
    border-radius: 99px;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    align-self: flex-start;
  }
  .tt-showcase-title { font-size: clamp(28px, 4vw, 40px); font-weight: 900; line-height: 1.1; margin: 0; }
  
  .tt-features-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
  .tt-features-list li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    font-size: 16px;
    color: #475569;
  }
  .tt-features-list .icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: #dcfce7;
    color: #16a34a;
    border-radius: 50%;
    flex-shrink: 0;
    font-size: 14px;
    margin-top: 2px;
  }
  .tt-feat-title { font-weight: 700; color: #0f172a; display: block; margin-bottom: 2px; }

  /* Price Block */
  .tt-price-block {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
    margin-top: 16px;
  }
  .tt-price-row {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .tt-price-now { font-size: 48px; font-weight: 900; color: #0f172a; line-height: 1; }
  .tt-price-was { font-size: 24px; color: #94a3b8; text-decoration: line-through; }
  .tt-price-save {
    background: #fee2e2;
    color: #b91c1c;
    padding: 6px 14px;
    border-radius: 99px;
    font-size: 14px;
    font-weight: 800;
  }

  /* ── TRANSFORMATION (Before/After) ── */
  .tt-transform-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-top: 48px;
  }
  .tt-state-card {
    background: white;
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 10px 30px -5px rgba(0,0,0,0.05);
  }
  .tt-state-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
    padding-bottom: 24px;
    border-bottom: 1px solid #f1f5f9;
  }
  .tt-state-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
  }
  .tt-state-card.before .tt-state-icon { background: #fee2e2; color: #ef4444; }
  .tt-state-card.after .tt-state-icon { background: #dcfce7; color: #22c55e; }
  .tt-state-title { font-size: 24px; font-weight: 800; margin: 0; }
  
  .tt-state-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 20px; }
  .tt-state-list li {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    font-size: 16px;
    color: #475569;
  }
  .tt-state-list li::before {
    content: '✖';
    font-family: system-ui, sans-serif;
    color: #ef4444;
    font-weight: 900;
    margin-top: 2px;
  }
  .tt-state-card.after .tt-state-list li::before {
    content: '✔';
    color: #22c55e;
  }

  /* ── THE CONTENTS (Inventory) ── */
  .tt-inventory-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }
  .tt-inv-card {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
    display: flex;
    flex-direction: column;
  }
  .tt-inv-num {
    font-size: 48px;
    font-weight: 900;
    color: #38bdf8;
    line-height: 1;
    margin-bottom: 16px;
  }
  .tt-inv-title { font-size: 20px; font-weight: 800; color: #0f172a; margin: 0 0 12px; }
  .tt-inv-desc { color: #64748b; font-size: 15px; margin: 0; }

  /* ── VALUE STACK ── */
  .tt-val-container { max-width: 800px; margin: 0 auto; }
  .tt-val-box {
    background: white;
    border-radius: 24px;
    padding: 48px;
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.1);
  }
  .tt-val-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 0;
    border-bottom: 1px solid #f1f5f9;
    font-size: 18px;
    color: #334155;
  }
  .tt-val-row strong { color: #0f172a; font-weight: 700; }
  .tt-val-row:last-of-type { border-bottom: none; }
  .tt-val-total {
    background: #f8fafc;
    border-radius: 16px;
    padding: 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 24px;
  }
  .tt-val-total-label { font-size: 24px; font-weight: 800; color: #0f172a; }
  .tt-val-total-price { font-size: 36px; font-weight: 900; color: #ef4444; text-decoration: line-through; }

  .tt-guarantee-box {
    display: flex;
    align-items: center;
    gap: 24px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 16px;
    padding: 32px;
    margin-top: 32px;
  }
  .tt-guarantee-box img { width: 80px; height: 80px; }
  .tt-gb-content h4 { font-size: 20px; font-weight: 800; color: #166534; margin: 0 0 8px; }
  .tt-gb-content p { color: #15803d; margin: 0; font-size: 15px; }

  /* ── TESTIMONIALS (Imported & Integrated) ── */
  .tt-reviews-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 48px;
  }

  .tt-review-card {
    background: #ffffff;
    border-radius: 16px;
    padding: 28px 24px;
    box-shadow: 0 4px 20px rgba(15, 23, 42, 0.04);
    border: 1px solid #e2e8f0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    transition: transform 0.25s ease;
  }
  .tt-review-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(15, 23, 42, 0.08); }

  .tt-review-stars { display: flex; gap: 3px; color: #f59e0b; font-size: 14px; }
  .tt-review-text { font-size: 14px; line-height: 1.7; color: #334155; flex: 1; font-style: italic; }
  
  .tt-review-author {
    display: flex; align-items: center; gap: 12px; border-top: 1px solid #f1f5f9; padding-top: 14px; margin-top: auto;
  }
  .tt-review-avatar {
    width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 800; color: white;
  }
  .tt-review-info { flex: 1; min-width: 0; }
  .tt-review-name { font-size: 14px; font-weight: 800; color: #0f172a; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tt-review-title { font-size: 12px; color: #64748b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tt-verified { font-size: 11px; font-weight: 700; color: #0ea5e9; display: flex; align-items: center; gap: 4px; margin-top: 4px; }

  /* Avatar gradients */
  .tt-av-1 { background: linear-gradient(135deg, #0ea5e9, #0369a1); }
  .tt-av-2 { background: linear-gradient(135deg, #14b8a6, #0f766e); }
  .tt-av-3 { background: linear-gradient(135deg, #8b5cf6, #6d28d9); }
  .tt-av-4 { background: linear-gradient(135deg, #f97316, #c2410c); }
  .tt-av-5 { background: linear-gradient(135deg, #ec4899, #be185d); }
  .tt-av-6 { background: linear-gradient(135deg, #10b981, #047857); }

  /* ── FAQ ── */
  .tt-faq-grid { max-width: 800px; margin: 48px auto 0; display: flex; flex-direction: column; gap: 16px; }
  .tt-faq-item {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 32px;
  }
  .tt-faq-item h3 { font-size: 18px; font-weight: 800; color: #0f172a; margin: 0 0 12px; }
  .tt-faq-item p { margin: 0; color: #475569; font-size: 16px; }

  /* ── RESPONSIVE RESPONSIVE ── */
  @media (max-width: 1024px) {
    .tt-showcase { grid-template-columns: 1fr; gap: 48px; }
    .tt-reviews-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 768px) {
    .tt-transform-grid { grid-template-columns: 1fr; }
    .tt-reviews-grid { grid-template-columns: repeat(2, 1fr); }
    .tt-hero { padding: 80px 0 60px; }
    .tt-guarantee-box { flex-direction: column; text-align: center; }
  }
  @media (max-width: 600px) {
    .tt-val-box { padding: 32px 20px; }
    .tt-val-row { font-size: 15px; }
    .tt-val-total { flex-direction: column; gap: 12px; }
    .tt-reviews-grid { grid-template-columns: 1fr; }
    .tt-price-row { flex-wrap: wrap; }
  }
</style>

