{% assign p1 = all_products['the-internal-family-systems-workbook-a-guide-to-discover-your-self-and-heal-your-parts-sounds-true-inner-workbooks'] %}
{% assign v1 = p1.variants.first %}
{% assign p2 = all_products['self-therapy-a-step-by-step-guide-to-creating-wholeness-using-ifs-a-cutting-edge-psychotherapy'] %}
{% assign v2 = p2.variants.first %}
{% assign p3 = all_products['the-self-led-internal-family-systems-workbook-learn-ifs-skills-to-understand-and-love-all-your-parts'] %}
{% assign v3 = p3.variants.first %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The IFS Mastery Bundle - 3 Essential Workbooks</title>
  <meta name="description" content="Get all three essential Internal Family Systems (IFS) workbooks for one low price of $29. Heal your parts, understand your inner self, and achieve wholeness." />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --brand: #2c7a7b;
      --brand-dark: #1d5657;
      --brand-light: #e6fffa;
      --accent: #f6ad55;
      --accent-hover: #dd6b20;
      --text-primary: #1a202c;
      --text-secondary: #4a5568;
      --bg: #ffffff;
      --surface: #f7fafc;
      --border: #e2e8f0;
      --shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
      --glass-bg: rgba(255, 255, 255, 0.9);
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-primary); line-height: 1.6; }

    /* Navigation */
    .bundle-nav { position: sticky; top: 0; z-index: 1000; background: var(--glass-bg); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .bundle-nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .bundle-logo { font-weight: 900; font-size: 1.25rem; color: var(--brand); text-decoration: none; }
    
    /* Buttons */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 800; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; border: none; font-size: 1.1rem; padding: 16px 32px; font-family: inherit; }
    .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent-hover)); color: #fff; box-shadow: 0 4px 14px rgba(221, 107, 32, 0.3); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(221, 107, 32, 0.4); }
    .btn-sm { font-size: 0.95rem; padding: 10px 20px; border-radius: 8px; }

    /* Hero */
    .bundle-hero { background: linear-gradient(135deg, var(--surface) 0%, var(--brand-light) 100%); padding: 80px 24px; text-align: center; }
    .hero-badge { display: inline-block; background: var(--accent); color: #fff; font-size: 0.85rem; font-weight: 800; padding: 6px 16px; border-radius: 999px; margin-bottom: 24px; text-transform: uppercase; letter-spacing: 1px; }
    .bundle-hero h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; color: var(--brand-dark); line-height: 1.1; margin-bottom: 24px; letter-spacing: -1px; }
    .bundle-hero p { font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto 40px; }
    .price-block { margin-bottom: 32px; }
    .price-current { font-size: 3rem; font-weight: 900; color: var(--text-primary); }
    .price-original { font-size: 1.25rem; text-decoration: line-through; color: #a0aec0; margin-left: 12px; font-weight: 600; }

    /* Books Grid */
    .books-section { padding: 80px 24px; background: #fff; }
    .section-title { text-align: center; font-size: 2.5rem; font-weight: 900; margin-bottom: 48px; color: var(--brand-dark); }
    .books-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; max-width: 1100px; margin: 0 auto; }
    .book-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 32px; text-align: center; transition: transform 0.3s ease; }
    .book-card:hover { transform: translateY(-8px); box-shadow: 0 12px 24px rgba(0,0,0,0.06); }
    .book-img { width: 100%; max-width: 200px; height: 280px; object-fit: contain; margin: 0 auto 24px; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
    .book-title { font-size: 1.25rem; font-weight: 800; line-height: 1.3; margin-bottom: 12px; color: var(--text-primary); }
    
    /* Trust Bar */
    .trust-bar { display: flex; flex-wrap: wrap; justify-content: center; gap: 40px; padding: 40px 24px; background: var(--brand-dark); color: #fff; }
    .trust-item { display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 1.1rem; }

    /* Sticky Bottom CTA */
    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; background: var(--glass-bg); backdrop-filter: blur(10px); border-top: 1px solid var(--border); padding: 16px 24px; z-index: 999; display: flex; justify-content: center; align-items: center; gap: 24px; box-shadow: 0 -4px 20px rgba(0,0,0,0.05); transform: translateY(100%); transition: transform 0.3s ease; }
    .sticky-cta.show { transform: translateY(0); }
    .sticky-cta-text { font-weight: 800; font-size: 1.1rem; }

    @media (max-width: 768px) {
      .bundle-hero h1 { font-size: 2.2rem; }
      .sticky-cta { flex-direction: column; text-align: center; gap: 12px; }
    }
  </style>
</head>
<body>

  <nav class="bundle-nav">
    <div class="bundle-nav-inner">
      <a href="/" class="bundle-logo">PsychoReads</a>
      <button class="btn btn-primary btn-sm" onclick="checkoutBundle()">Buy Bundle Now</button>
    </div>
  </nav>

  <header class="bundle-hero">
    <div class="hero-badge">Limited Time Offer</div>
    <h1>The Ultimate IFS Mastery Bundle</h1>
    <p>Everything you need to map your inner system, connect with your parts, and achieve true Self-leadership.</p>
    
    <div class="price-block">
      <span class="price-current">$29.00</span>
      <span class="price-original">$75.00 Value</span>
    </div>

    <button id="hero-btn" class="btn btn-primary" onclick="checkoutBundle()">
      🛒 Get All 3 Books for $29
    </button>
    <div style="margin-top: 16px; font-size: 0.9rem; color: var(--text-secondary); font-weight: 500;">
      Instant PDF Download • Secure Checkout
    </div>
  </header>

  <div class="trust-bar">
    <div class="trust-item"><span>📘</span> 3 Complete Workbooks</div>
    <div class="trust-item"><span>⚡</span> Instant Digital Access</div>
    <div class="trust-item"><span>🧠</span> Transform Your Inner World</div>
  </div>

  <section class="books-section">
    <h2 class="section-title">What's Inside The Bundle</h2>
    <div class="books-grid">
      
      <!-- Book 1 -->
      <div class="book-card">
        {% if p1.images.first %}
          <img src="{{ p1.images.first | img_url: '600x' }}" alt="{{ p1.title }}" class="book-img" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center;">Book 1</div>
        {% endif %}
        <h3 class="book-title">{{ p1.title | default: "The Internal Family Systems Workbook" }}</h3>
      </div>

      <!-- Book 2 -->
      <div class="book-card">
        {% if p2.images.first %}
          <img src="{{ p2.images.first | img_url: '600x' }}" alt="{{ p2.title }}" class="book-img" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center;">Book 2</div>
        {% endif %}
        <h3 class="book-title">{{ p2.title | default: "Self-Therapy: A Step-by-Step Guide" }}</h3>
      </div>

      <!-- Book 3 -->
      <div class="book-card">
        {% if p3.images.first %}
          <img src="{{ p3.images.first | img_url: '600x' }}" alt="{{ p3.title }}" class="book-img" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center;">Book 3</div>
        {% endif %}
        <h3 class="book-title">{{ p3.title | default: "The Self-Led IFS Workbook" }}</h3>
      </div>

    </div>
  </section>

  <div class="bundle-hero" style="background: var(--brand-dark); color: #fff;">
    <h2 style="font-size: 2.5rem; margin-bottom: 24px; color: #fff;">Start Your Healing Journey Today</h2>
    <p style="color: rgba(255,255,255,0.8);">Get instant access to all three workbooks and begin applying IFS techniques immediately.</p>
    <button class="btn btn-primary" onclick="checkoutBundle()" style="background: #fff; color: var(--brand-dark); box-shadow: none;">
      🛒 Get The Bundle — $29
    </button>
  </div>

  <div class="sticky-cta" id="sticky-cta">
    <div class="sticky-cta-text">IFS Mastery Bundle — $29.00</div>
    <button class="btn btn-primary btn-sm" onclick="checkoutBundle()">Buy Now</button>
  </div>

  <script>
    // Reveal sticky CTA on scroll
    const heroBtn = document.getElementById('hero-btn');
    const stickyCta = document.getElementById('sticky-cta');
    
    window.addEventListener('scroll', () => {
      if (heroBtn.getBoundingClientRect().bottom < 0) {
        stickyCta.classList.add('show');
      } else {
        stickyCta.classList.remove('show');
      }
    });

    // Handle Add to Cart & Checkout
    function checkoutBundle() {
      const v1 = '{{ v1.id }}';
      const v2 = '{{ v2.id }}';
      const v3 = '{{ v3.id }}';

      if (!v1 || !v2 || !v3) {
        alert("Bundle configuration error. Missing variants.");
        return;
      }

      // Update button states
      document.querySelectorAll('.btn-primary').forEach(btn => {
        const originalText = btn.innerHTML;
        btn.innerHTML = "Processing...";
        btn.disabled = true;
      });

      // Clear cart first, then add the 3 items, then redirect
      fetch('/cart/clear.js', { method: 'POST' })
        .then(() => {
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({
              items: [
                { id: v1, quantity: 1 },
                { id: v2, quantity: 1 },
                { id: v3, quantity: 1 }
              ]
            })
          });
        })
        .then(res => res.json())
        .then(() => {
          // If you have a specific discount code to enforce $29, append it here
          // window.location.href = '/checkout?discount=BUNDLE29';
          window.location.href = '/checkout';
        })
        .catch(err => {
          console.error("Error creating bundle checkout:", err);
          alert("There was an error creating your bundle. Please try again.");
          document.querySelectorAll('.btn-primary').forEach(btn => {
            btn.innerHTML = "Buy Bundle Now";
            btn.disabled = false;
          });
        });
    }
  </script>

</body>
</html>
