    <div class="sl-trust-item"><span>🏅</span> Complex PTSD Focused</div>
    <div class="sl-trust-item"><span>🧠</span> IFS-Based Approach</div>
    <div class="sl-trust-item"><span>💜</span> Trauma-Informed</div>
    <div class="sl-trust-item"><span>⚡</span> Instant PDF Access</div>
    <div class="sl-trust-item"><span>🌍</span> English Language</div>
  </div>

  <!-- INSIDE THE BOOK -->
  <div class="sl-section" style="background: var(--surface);">
    <div class="sl-section-inner">
      <div style="text-align: center;">
        <div class="sl-label">Inside the Book</div>
        <h2 class="sl-title">A Bridge Between Trauma & Healing</h2>
