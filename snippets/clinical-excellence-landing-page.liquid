{% comment %}
  =============================================================================
  BUNDLE #11 — CLINICAL EXCELLENCE & INNOVATION
  Theme: Midnight Professional (Deep Navy & Medical Teal)
  =============================================================================
{% endcomment %}

{% assign bundle_handles = "lehnes-pharmacotherapeutics-for-advanced-practice-nurses-and-physician-assistants,measurement-of-nursing-outcomes-2nd-edition-volume-2-client-outcomes-and-quality-of-care,machine-learning-and-ai-for-healthcare-big-data-for-improved-health-outcomes,the-clinical-application-of-outcomes-assessment,working-with-attachment-trauma-clinical-application-of-the-adult-attachment-projective-picture-system" | split: "," %}

{% assign bundle_price = 1999 %}
{% assign total_compare_price = 0 %}
{% for handle in bundle_handles %}
  {% assign current_product = all_products[handle] %}
  {% if current_product != empty %}
    {% assign variant = current_product.first_available_variant %}
    {% assign total_compare_price = total_compare_price | plus: variant.compare_at_price %}
  {% endif %}
{% endfor %}

{% comment %} Verified CDN Assets {% endcomment %}
{% assign img_lehne = "https://cdn.shopify.com/s/files/1/0741/5070/7372/files/61Ssa_ruAeL._SY522.jpg?v=1771939449" %}
{% assign img_nursing = "https://cdn.shopify.com/s/files/1/0741/5070/7372/files/61mrBb7gWgL._SL1500.jpg?v=1771938987" %}
{% assign img_ai = "https://cdn.shopify.com/s/files/1/0741/5070/7372/files/61Ec5YmZxmL._SL1180.jpg?v=1771938123" %}
{% assign img_outcomes = "https://cdn.shopify.com/s/files/1/0741/5070/7372/files/41x5V67xUkL.jpg?v=1771933391" %}
{% assign img_trauma = "https://cdn.shopify.com/s/files/1/0741/5070/7372/files/71-Vlg8l0vL._SY522.jpg?v=1771932868" %}

<style>
  /* =============================================
     CLINICAL EXCELLENCE — Midnight Professional
     ============================================= */
  .cl-landing-page {
    font-family: 'Inter', -apple-system, sans-serif;
    color: #e2e8f0;
    line-height: 1.6;
    background-color: #0f172a;
    padding-bottom: 120px;
    overflow-x: hidden;
  }
  .cl-container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
  .cl-section { padding: 5rem 0; }

  h1, h2, h3 { font-family: "Georgia", serif; line-height: 1.1; font-weight: 900; color: #ffffff; }
  h2 { font-size: 2.75rem; margin-bottom: 2.5rem; text-align: center; letter-spacing: -0.02em; }
  h3 { font-size: 1.6rem; margin-bottom: 0.75rem; color: #38bdf8; }
  p { font-size: 1.1rem; color: #94a3b8; margin-bottom: 1.5rem; }

  /* ---- Hero ---- */
  .cl-hero {
    text-align: center;
    padding: 7rem 1rem 6rem;
    background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%);
    position: relative;
    border-bottom: 1px solid rgba(56, 189, 248, 0.1);
  }
  .cl-hero::before {
    content: '';
    position: absolute; inset: 0;
    background: url('https://www.transparenttextures.com/patterns/cubes.png');
    opacity: 0.03; pointer-events: none;
  }
  .cl-eyebrow {
    display: inline-block;
    background: rgba(56, 189, 248, 0.1);
    color: #38bdf8;
    padding: 0.5rem 1.5rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 2rem;
    border: 1px solid rgba(56, 189, 248, 0.2);
  }
  .cl-hero-title {
    font-size: 4rem;
    margin-bottom: 1.5rem;
    letter-spacing: -0.04em;
    color: #ffffff;
  }
  .cl-hero-title span { color: #0d9488; } /* Medical Teal */
  .cl-hero-subtitle {
    font-size: 1.35rem;
    max-width: 800px;
    margin: 0 auto 4rem;
    color: #94a3b8;
  }

  /* ---- Book Grid Showcase ---- */
  .cl-books-row {
    display: flex; justify-content: center; align-items: flex-end;
    gap: 1.5rem; margin-bottom: 4rem; flex-wrap: wrap;
  }
  .cl-book-item {
    width: 160px;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    filter: drop-shadow(0 20px 30px rgba(0,0,0,0.5));
  }
  .cl-book-item:hover {
    transform: translateY(-15px) scale(1.08) rotate(2deg);
    filter: drop-shadow(0 30px 50px rgba(13, 148, 136, 0.3));
  }
  .cl-book-img {
    width: 100%; border-radius: 6px;
    box-shadow: -10px 15px 30px rgba(0,0,0,0.8), inset 0 0 1px rgba(255,255,255,0.2);
  }

  /* ---- Thesis / Professional Value ---- */
  .cl-thesis {
    background: rgba(30, 41, 59, 0.5);
    backdrop-filter: blur(10px);
    border-radius: 32px; padding: 4rem;
    border: 1px solid rgba(56, 189, 248, 0.1);
    margin-top: -3rem; position: relative; z-index: 10;
    box-shadow: 0 40px 80px -20px rgba(0,0,0,0.6);
  }
  .cl-thesis h2 { font-family: "Inter", sans-serif; font-size: 2.25rem; font-weight: 800; text-align: left; }
  .cl-thesis p { font-size: 1.25rem; color: #cbd5e1; }
  .cl-thesis strong { color: #38bdf8; font-weight: 700; }

  /* ---- Breakdown Cards ---- */
  .cl-card {
    display: grid; grid-template-columns: 200px 1fr;
    gap: 4rem; background: #1e293b;
    padding: 4rem; border-radius: 24px; margin-bottom: 2rem;
    align-items: center; border: 1px solid rgba(56, 189, 248, 0.05);
    transition: border 0.3s;
  }
  .cl-card:hover { border-color: rgba(56, 189, 248, 0.3); }
  .cl-card-img {
    width: 100%; border-radius: 8px; box-shadow: -15px 20px 40px rgba(0,0,0,0.7);
  }
  .cl-tag {
    display: inline-block; padding: 0.3rem 1rem;
    background: rgba(13, 148, 136, 0.1); color: #2dd4bf;
    border-radius: 6px; font-weight: 700; font-size: 0.75rem;
    margin-bottom: 1.25rem; text-transform: uppercase; letter-spacing: 0.1em;
    border: 1px solid rgba(13, 148, 136, 0.2);
  }
  .cl-list { list-style: none; padding: 0; margin-top: 1.5rem; }
  .cl-list li {
    padding-left: 2rem; position: relative; margin-bottom: 0.75rem;
    color: #cbd5e1; font-size: 1.05rem;
  }
  .cl-list li::before {
    content: "✓"; position: absolute; left: 0; color: #0d9488;
    font-weight: 900; font-size: 1.2rem;
  }

  /* ---- Pricing ---- */
  .cl-pricing {
    background: radial-gradient(circle at bottom, #1e293b, #0f172a);
    border-radius: 32px; padding: 5rem 2rem; text-align: center;
    border: 1px solid rgba(56, 189, 248, 0.1); margin: 6rem 0;
  }
  .cl-price-main { font-size: 5rem; font-weight: 900; color: #ffffff; line-height: 1; }
  .cl-price-strike { font-size: 1.5rem; color: #64748b; text-decoration: line-through; margin-left: 1rem; }
  .cl-savings {
    display: inline-block; background: #0d9488; color: white;
    padding: 0.6rem 2rem; border-radius: 999px; font-weight: 800; margin-top: 2rem;
    box-shadow: 0 10px 20px rgba(13, 148, 136, 0.3);
  }

  .cl-btn {
    display: inline-block; background: #ffffff; color: #0f172a;
    padding: 1.25rem 4rem; border-radius: 100px; font-size: 1.4rem;
    font-weight: 900; text-decoration: none; margin-top: 3rem;
    transition: all 0.3s; border: none; cursor: pointer;
  }
  .cl-btn:hover { transform: scale(1.05); box-shadow: 0 0 40px rgba(255,255,255,0.2); background: #f8fafc; }

  /* ---- Sticky Checkout ---- */
  .cl-sticky {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(15px);
    padding: 1rem 2rem; display: flex; align-items: center; justify-content: center;
    gap: 3rem; border-top: 1px solid rgba(56, 189, 248, 0.2);
    z-index: 1000; transform: translateY(100%); transition: transform 0.4s;
  }
  .cl-sticky.visible { transform: translateY(0); }
  .cl-sticky-info { display: flex; flex-direction: column; }
  .cl-sticky-price { font-size: 1.5rem; font-weight: 900; color: #38bdf8; }

  @media (max-width: 768px) {
    .cl-hero-title { font-size: 2.75rem; }
    .cl-thesis { padding: 2.5rem 1.5rem; }
    .cl-card { grid-template-columns: 1fr; gap: 2rem; padding: 2.5rem 1.5rem; text-align: center; }
    .cl-card-img { max-width: 180px; margin: 0 auto; }
    .cl-list li { text-align: left; }
    .cl-sticky { padding: 0.75rem 1rem; gap: 1rem; justify-content: space-between; }
    .cl-sticky-title { display: none; }
    .cl-btn { width: 100%; padding: 1rem; }
  }
</style>

<div class="cl-landing-page">
  <!-- HERO -->
  <header class="cl-hero">
    <div class="cl-container">
      <div class="cl-eyebrow">Advanced Professional Series</div>
      <h1 class="cl-hero-title">The <span>Clinical Excellence</span> & Innovation Library</h1>
      <p class="cl-hero-subtitle">Elevate your practice with the definitive digital collection on pharmacotherapeutics, medical AI, and evidence-based clinical outcomes.</p>

      <div class="cl-books-row">
        <div class="cl-book-item"><img src="{{ img_lehne }}" class="cl-book-img"></div>
        <div class="cl-book-item"><img src="{{ img_nursing }}" class="cl-book-img"></div>
        <div class="cl-book-item"><img src="{{ img_ai }}" class="cl-book-img"></div>
        <div class="cl-book-item"><img src="{{ img_outcomes }}" class="cl-book-img"></div>
        <div class="cl-book-item"><img src="{{ img_trauma }}" class="cl-book-img"></div>
      </div>

      <a href="#purchase" class="cl-btn">Secure Your Collection →</a>
    </div>
  </header>

  <!-- THESIS -->
  <main class="cl-container">
    <div class="cl-thesis">
      <h2>Transforming Clinical Competence into Operational Excellence</h2>
      <p>In the modern clinical environment, technical skill alone is no longer enough. The future belongs to the <strong>Multidisciplinary Practitioner</strong> — the provider who masters advanced pharmacology, understands the predictive power of <strong>Machine Learning</strong>, and can rigorously measure the quality of care through standardized outcomes.</p>
      <p>This curation represents the "Next Level" of professional development. It bridges the gap between patient-facing care and the high-level <strong>systems-thinking</strong> required of APNs, PAs, and healthcare administrators in the Big Data era.</p>
    </div>

    <!-- CARDS -->
    <div class="cl-section">
      <!-- LEHNE -->
      <div class="cl-card">
        <img src="{{ img_lehne }}" class="cl-card-img">
        <div>
          <span class="cl-tag">Core Pharmacotherapeutics</span>
          <h3>Lehne's Pharmacotherapeutics for APNs and PAs</h3>
          <p>The gold standard for advanced prescribing. This isn't just a textbook; it's a clinical framework for managing complex regimens with precision and confidence.</p>
          <ul class="cl-list">
            <li>Integrated physiological and pharmacological coverage.</li>
            <li>Focus on "Prescribing Implications" for advanced practice roles.</li>
            <li>Essential for high-risk clinical decision support.</li>
          </ul>
        </div>
      </div>

      <!-- NURSING OUTCOMES -->
      <div class="cl-card">
        <img src="{{ img_nursing }}" class="cl-card-img">
        <div>
          <span class="cl-tag">Evidence-Based Leadership</span>
          <h3>Measurement of Nursing Outcomes</h3>
          <p>Volume 2 focus: Client Outcomes & Quality of Care. Master the architecture of outcome measurement to prove the value and efficacy of clinical interventions.</p>
          <ul class="cl-list">
            <li>Standardized tools for clinical nurse specialists.</li>
            <li>Frameworks for tracking and improving patient safety.</li>
            <li>Indispensable for nursing administration and research.</li>
          </ul>
        </div>
      </div>

      <!-- AI -->
      <div class="cl-card">
        <img src="{{ img_ai }}" class="cl-card-img">
        <div>
          <span class="cl-tag">The Technological Frontier</span>
          <h3>Machine Learning & AI for Healthcare</h3>
          <p>Navigate the most significant shift in medical history. Learn how AI is driving Big Data for improved health outcomes, from diagnostics to population health.</p>
          <ul class="cl-list">
            <li>Demystifying predictive analytics for medical providers.</li>
            <li>Ethics and implementation of AI in clinical workflows.</li>
            <li>Case studies on data-driven health improvements.</li>
          </ul>
        </div>
      </div>

      <!-- OUTCOMES ASSESSMENT -->
      <div class="cl-card">
        <img src="{{ img_outcomes }}" class="cl-card-img">
        <div>
          <span class="cl-tag">Clinical Methodology</span>
          <h3>The Clinical Application of Outcomes Assessment</h3>
          <p>A practical guide to integrating assessment tools into daily practice. Shift from subjective observation to objective, measurable clinical success.</p>
          <ul class="cl-list">
            <li>Bridging the gap between theory and bedside application.</li>
            <li>Standardizing patient progress tracking.</li>
            <li>Essential for value-based care reporting.</li>
          </ul>
        </div>
      </div>

      <!-- ATTACHMENT TRAUMA -->
      <div class="cl-card">
        <img src="{{ img_trauma }}" class="cl-card-img">
        <div>
          <span class="cl-tag">Advanced Diagnostics</span>
          <h3>Working with Attachment Trauma</h3>
          <p>Explore the Clinical Application of the Adult Attachment Projective Picture System. A sophisticated approach to diagnosing and treating trauma in clinical settings.</p>
          <ul class="cl-list">
            <li>Deep dive into the AAP projective picture system.</li>
            <li>Understanding internal working models of attachment.</li>
            <li>Advanced therapeutic strategies for complex trauma.</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- PRICING -->
    <div class="cl-pricing" id="purchase">
      <h2>Access the Professional Standard</h2>
      <p>5 Global Volumes. 1 Unbeatable Collection.</p>
      <div class="cl-price-main">
        {{ bundle_price | money }} <span class="cl-price-strike">{{ total_compare_price | money }}</span>
      </div>
      <div class="cl-savings">
        Save {{ total_compare_price | minus: bundle_price | money }} Instantly
      </div>
      
      {% form 'cart', cart %}
        {% for handle in bundle_handles %}
          {% assign current_product = all_products[handle] %}
          {% if current_product != empty %}
            {% assign variant = current_product.first_available_variant %}
            <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
          {% endif %}
        {% endfor %}
        <input type="hidden" name="checkout" value="Checkout" />
        <button type="submit" class="cl-btn" style="width:100%; max-width:480px;">Checkout Securely</button>
      {% endform %}
      <p style="margin-top: 2rem; color: #475569; font-size: 0.9rem;">Instant Digital Access • Secure Encryption • 30-Day Guarantee</p>
    </div>
  </main>

  <!-- STICKY BAR -->
  <div class="cl-sticky" id="cl-sticky">
    <span class="cl-sticky-title" style="font-weight: 800;">Clinical Excellence & Innovation Library</span>
    <span class="cl-sticky-price">{{ bundle_price | money }}</span>
    {% form 'cart', cart %}
      {% for handle in bundle_handles %}
        {% assign current_product = all_products[handle] %}
        {% if current_product != empty %}
          {% assign variant = current_product.first_available_variant %}
          <input type="hidden" name="updates[{{ variant.id }}]" value="1" />
        {% endif %}
      {% endfor %}
      <input type="hidden" name="checkout" value="Checkout" />
      <button type="submit" class="cl-btn" style="margin:0; padding: 0.75rem 2rem; font-size: 1rem;">Buy Now</button>
    {% endform %}
  </div>
</div>

<script>
  (function() {
    var sticky = document.getElementById('cl-sticky');
    var purchase = document.getElementById('purchase');
    window.addEventListener('scroll', function() {
      if(window.scrollY > 800 && purchase.getBoundingClientRect().top > window.innerHeight) {
        sticky.classList.add('visible');
      } else {
        sticky.classList.remove('visible');
      }
    });
  })();
</script>
